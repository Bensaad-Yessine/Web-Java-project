{% extends 'FrontBase.html.twig' %}

{% block body %}
    {% set classeRef = attempt.matiere.classes|first %}

    <div style="max-width: 980px; margin: 24px auto; padding: 0 16px; color:#111827;">
        <div style="background:#fff; border:1px solid #d1d5db; border-radius:14px; padding:20px; margin-bottom:16px;">
            <h1 style="margin:0 0 8px; font-size:24px; color:#111827;">Résultats — {{ attempt.matiere.nom }}</h1>
            <p style="margin:0; color:#374151; font-weight:600;">
                Score: {{ attempt.correctCount }}/{{ attempt.totalCount }} ({{ attempt.percent|number_format(0) }}%)
            </p>
        </div>

        {% for detail in details %}
            <div style="background:#fff; border:1px solid #d1d5db; border-radius:14px; padding:16px; margin-bottom:10px; color:#111827;">
                <div style="font-weight:700; margin-bottom:6px; color:#111827;">{{ loop.index }}. {{ detail.question.question }}</div>
                <div style="margin-bottom:6px; color: {{ detail.isCorrect ? '#166534' : '#991b1b' }}; font-weight:700;">
                    {{ detail.isCorrect ? '✅ Correct' : '❌ Incorrect' }}
                </div>
                <div style="font-size:14px; color:#1f2937;">
                    Votre réponse: {{ detail.userAnswer ?: '—' }} · Bonne réponse: {{ detail.correctAnswer }}
                </div>
                {% if detail.question.explanation %}
                    <div style="margin-top:8px; padding:8px 10px; border-radius:8px; background:#f9fafb; color:#374151;">
                        {{ detail.question.explanation }}
                    </div>
                {% endif %}
            </div>
        {% endfor %}

        <div style="display:flex; gap:10px; align-items:center; margin-top:12px;">
            <a href="{{ path('app_quiz_matiere', {id: attempt.matiere.id}) }}" style="padding:10px 16px; border-radius:10px; background:#2563eb; color:#fff; text-decoration:none; font-weight:700;">
                Refaire le quiz
            </a>
            {% if classeRef %}
                <a href="{{ path('app_classe_front_show', {id: classeRef.id}) }}" style="padding:10px 16px; border-radius:10px; background:#e5e7eb; color:#111827; text-decoration:none; font-weight:600;">
                    Retour à la classe
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}