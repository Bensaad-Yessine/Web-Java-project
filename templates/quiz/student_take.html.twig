{% extends 'FrontBase.html.twig' %}

{% block body %}
    {% set classeRef = matiere.classes|first %}

    <div style="max-width: 980px; margin: 24px auto; padding: 0 16px; color:#111827;">
        <div style="background:#fff; border:1px solid #d1d5db; border-radius:14px; padding:20px; margin-bottom:16px;">
            <h1 style="margin:0 0 8px; font-size:24px; color:#111827;">Quiz — {{ matiere.nom }}</h1>
            <p style="margin:0; color:#374151; font-weight:600;">
                {% if classeRef %}Classe {{ classeRef.nom }} · {% endif %}
                {{ questions|length }} question(s)
            </p>
        </div>

        <form method="post" action="{{ path('app_quiz_submit', {id: matiere.id}) }}" id="quiz-form">
            {% for question in questions %}
                <div style="background:#fff; border:1px solid #d1d5db; border-radius:14px; padding:18px; margin-bottom:12px; color:#111827;">
                    <div style="font-weight:700; margin-bottom:10px; color:#111827;">Question {{ loop.index }} / {{ questions|length }}</div>
                    <div style="margin-bottom:12px; color:#1f2937;">{{ question.question }}</div>

                    <label style="display:block; margin:6px 0; color:#1f2937;">
                        <input type="radio" name="answers[{{ question.id }}]" value="A" required>
                        A) {{ question.choiceA }}
                    </label>
                    <label style="display:block; margin:6px 0; color:#1f2937;">
                        <input type="radio" name="answers[{{ question.id }}]" value="B" required>
                        B) {{ question.choiceB }}
                    </label>
                    {% if question.choiceC %}
                        <label style="display:block; margin:6px 0; color:#1f2937;">
                            <input type="radio" name="answers[{{ question.id }}]" value="C" required>
                            C) {{ question.choiceC }}
                        </label>
                    {% endif %}
                    {% if question.choiceD %}
                        <label style="display:block; margin:6px 0; color:#1f2937;">
                            <input type="radio" name="answers[{{ question.id }}]" value="D" required>
                            D) {{ question.choiceD }}
                        </label>
                    {% endif %}
                </div>
            {% endfor %}

            <div style="display:flex; gap:10px; align-items:center;">
                <button type="submit" style="padding:10px 16px; border:0; border-radius:10px; background:#16a34a; color:#fff; font-weight:700; cursor:pointer;">
                    Soumettre le quiz
                </button>
                {% if classeRef %}
                    <a href="{{ path('app_classe_front_show', {id: classeRef.id}) }}" style="padding:10px 16px; border-radius:10px; background:#e5e7eb; color:#111827; text-decoration:none; font-weight:600;">
                        Retour à la classe
                    </a>
                {% endif %}
            </div>
        </form>
    </div>
{% endblock %}