{% extends 'front/base.html.twig' %}

{% block title %}Salles{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Salles <span class="badge bg-secondary ms-2">{{ salles|length }}</span></h1>
        <p class="page-subtitle text-muted">Consultez les informations de chaque salle</p>
    </div>
    <a href="https://www.google.com/maps" target="_blank" class="btn btn-outline-primary">
        <i class="mdi mdi-map-marker-outline me-2"></i>Carte
    </a>
</div>

<div class="row">
    {% for salle in salles %}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Salle {{ salle.name }}</h5>
                    <p class="card-text">
                        Bloc {{ salle.block }} — Étage {{ salle.etage }}<br>
                        Capacité: {{ salle.capacite ?: 'N/A' }}
                    </p>
                    <a href="https://www.google.com/maps/search/?api=1&query={{ salle.block }}+{{ salle.etage }}" target="_blank" class="btn btn-primary btn-sm">
                        <i class="mdi mdi-map-marker"></i> Voir sur la carte
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">Aucune salle disponible pour le moment.</div>
        </div>
    {% endfor %}
</div>
{% endblock %}
