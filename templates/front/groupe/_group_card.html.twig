{# templates/front/groupe/_group_card.html.twig #}
<div class="group-card" 
     data-matiere="{{ groupe.matiere|lower }}"
     data-status="{{ groupe.statut }}"
     data-members="{{ groupe.nbrMembre }}"
     data-id="{{ groupe.id }}"
     data-created="{{ groupe.CreatedAt ? groupe.CreatedAt|date('c') : '' }}">
    
    <div class="card h-100">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); position: relative; overflow: hidden; height: 120px; display: flex; align-items: flex-end; justify-content: space-between; padding: 12px;">
            {% if groupe.logoImageName %}
                <img src="{{ vich_uploader_asset(groupe, 'logoImageFile') }}" 
                     alt="Logo de {{ groupe.nomProjet }}"
                     style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; z-index: 0;">
                <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.3); z-index: 1;"></div>
            {% endif %}
            <div class="group-avatar" style="width: 40px; height: 40px; font-size: 16px; {% if not groupe.logoImageName %}background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #667eea; font-weight: bold;{% else %}color: white;{% endif %}; z-index: 2; position: relative;">
                {% if not groupe.logoImageName %}GP{{ groupe.id }}{% endif %}
            </div>
            <span class="badge bg-white text-dark" style="z-index: 2; position: relative;">
                {{ groupe.nbrMembre }} membre(s)
            </span>
        </div>
        
        <div class="card-body">
            <h5 class="card-title">{{ groupe.nomProjet }}</h5>
            <p class="text-muted mb-2">
                <i class="mdi mdi-book-open me-1"></i>
                {{ groupe.matiere }}
            </p>
            
            <div class="mb-3">
                {% if groupe.statut == 'Actif' %}
                    <span class="badge bg-success">
                        <i class="mdi mdi-check-circle me-1"></i>{{ groupe.statut }}
                    </span>
                {% elseif groupe.statut == 'Terminé' %}
                    <span class="badge bg-info">
                        <i class="mdi mdi-flag-checkered me-1"></i>{{ groupe.statut }}
                    </span>
                {% elseif groupe.statut == 'En pause' %}
                    <span class="badge bg-warning">
                        <i class="mdi mdi-pause-circle me-1"></i>{{ groupe.statut }}
                    </span>
                {% elseif groupe.statut == 'Non actif' %}
                    <span class="badge bg-secondary">
                        <i class="mdi mdi-close-circle me-1"></i>{{ groupe.statut }}
                    </span>
                {% else %}
                    <span class="badge bg-secondary">{{ groupe.statut }}</span>
                {% endif %}
            </div>
            
            <p class="card-text">
                {{ groupe.description|length > 150 ? groupe.description|slice(0, 150) ~ '...' : groupe.description }}
            </p>
            
            <div class="mt-3">
                <small class="text-muted">
                    <i class="mdi mdi-calendar me-1"></i>
                    Créé le: {{ groupe.CreatedAt ? groupe.CreatedAt|date('d/m/Y') : 'N/A' }}
                </small>
            </div>
        </div>
        
        <div class="card-footer bg-transparent">
            <div class="d-flex justify-content-between">
                <a href="{{ path('front_groupe_projet_show', {'id': groupe.id}) }}" 
                   class="btn btn-primary btn-sm">
                    <i class="mdi mdi-eye me-1"></i> Voir
                </a>
                
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('front_groupe_projet_edit', {'id': groupe.id}) }}" 
                       class="btn btn-outline-secondary btn-sm">
                        <i class="mdi mdi-pencil me-1"></i> Modifier
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>