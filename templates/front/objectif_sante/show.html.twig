    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Détails objectif page loaded');
            
            // Animation des cartes
            const cards = document.querySelectorAll('.card');
            cards.forEach(card => {
                card.addEventListener('mouseenter', () => {
                    card.style.transform = 'translateY(-8px)';
                });
                
                card.addEventListener('mouseleave', () => {
                    card.style.transform = 'translateY(0)';
                });
            });

            // Ripple effect pour les boutons
            const buttons = document.querySelectorAll('.btn');
            buttons.forEach(button => {
                button.addEventListener('click', function(e) {
                    const ripple = document.createElement('span');
                    const rect = this.getBoundingClientRect();
                    const size = Math.max(rect.width, rect.height);
                    const x = e.clientX - rect.left - size / 2;
                    const y = e.clientY - rect.top - size / 2;
                    
                    ripple.style.cssText = `
                        position: absolute;
                        border-radius: 50%;
                        background: rgba(255, 255, 255, 0.3);
                        transform: scale(0);
                        animation: ripple 0.6s linear;
                        width: ${size}px;
                        height: ${size}px;
                        top: ${y}px;
                        left: ${x}px;
                        pointer-events: none;
                    `;
                    
                    this.appendChild(ripple);
                    
                    setTimeout(() => {
                        ripple.remove();
                    }, 600);
                });
            });

            // Confirmation pour la suppression
            const deleteForm = document.querySelector('form[action*="delete"]');
            if (deleteForm) {
                deleteForm.addEventListener('submit', function(e) {
                    if (!confirm('Êtes-vous sûr de vouloir supprimer cet objectif ? Cette action est irréversible.')) {
                        e.preventDefault();
                    }
                });
            }

            // Animate progress bar
            const progressFill = document.querySelector('.progress-fill');
            if (progressFill) {
                // Reset width to 0 then animate to actual value
                const finalWidth = progressFill.style.width;
                progressFill.style.width = '0%';
                
                setTimeout(() => {
                    progressFill.style.transition = 'width 1.5s cubic-bezier(0.4, 0, 0.2, 1)';
                    progressFill.style.width = finalWidth;
                }, 300);
            }

            // Add ripple animation
            const style = document.createElement('style');
            style.textContent = `
                @keyframes ripple {
                    to {
                        transform: scale(4);
                        opacity: 0;
                    }
                }
                
                @keyframes shimmer {
                    0% { left: -100%; }
                    100% { left: 100%; }
                }
                
                @keyframes fadeIn {
                    from { opacity: 0; transform: translateY(20px); }
                    to { opacity: 1; transform: translateY(0); }
                }
                
                @keyframes pulse {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.5; }
                }
            `;
            document.head.appendChild(style);
        });
    </script>
    <script>
document.addEventListener('DOMContentLoaded', async () => {
  const card = document.getElementById('coachingCard');
  if (!card) return;

  const url = card.dataset.url;

  const loadingEl = document.getElementById('coachingLoading');
  const errorEl = document.getElementById('coachingError');
  const contentEl = document.getElementById('coachingContent');

  const trendBadge = document.getElementById('trendBadge');
  const avgScore = document.getElementById('avgScore');
  const lastScore = document.getElementById('lastScore');
  const prevScore = document.getElementById('prevScore');
  const deltaScore = document.getElementById('deltaScore');

  const coachMessage = document.getElementById('coachMessage');
  const coachReasons = document.getElementById('coachReasons');
  const coachRecs = document.getElementById('coachRecs');

  function setTrendBadge(trend) {
    trendBadge.textContent = trend;

    // reset classes
    trendBadge.className = 'badge';

    if (trend === 'UP') {
      trendBadge.classList.add('badge-success');
      trendBadge.textContent = 'UP ↑';
    } else if (trend === 'DOWN') {
      trendBadge.classList.add('badge-danger');
      trendBadge.textContent = 'DOWN ↓';
    } else {
      trendBadge.classList.add('badge-info');
      trendBadge.textContent = 'STABLE →';
    }
  }

  function esc(str) {
    return String(str ?? '').replace(/[&<>"']/g, s => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[s]));
  }

  try {
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    if (!res.ok) throw new Error('HTTP ' + res.status);

    const data = await res.json();

    // scores
    avgScore.textContent = data?.scores?.scoreMoyen ?? '-';
    lastScore.textContent = data?.scores?.lastScore ?? '-';
    prevScore.textContent = data?.scores?.previousScore ?? '-';
    deltaScore.textContent = data?.scores?.delta ?? '-';

    // trend + message
    setTrendBadge(data?.trend || 'STABLE');
    coachMessage.textContent = data?.message || '';

    // reasons
    coachReasons.innerHTML = '';
    (data?.reasons || []).forEach(r => {
      const li = document.createElement('li');
      li.textContent = r;
      coachReasons.appendChild(li);
    });

    // recommendations
    coachRecs.innerHTML = '';
    (data?.recommendations || []).forEach(rec => {
      const priority = rec.priority || 'MOYENNE';

      let badgeClass = 'badge-warning';
      if (priority === 'HAUTE') badgeClass = 'badge-danger';
      if (priority === 'BASSE') badgeClass = 'badge-success';

      const actions = (rec.actions || []).map(a => `<li>${esc(a)}</li>`).join('');

      const html = `
        <div class="detail-item" style="padding:18px;">
          <div style="display:flex; justify-content:space-between; gap:12px; align-items:center; margin-bottom:10px;">
            <div style="font-weight:800; color: var(--gray-900);">${esc(rec.title)}</div>
            <span class="badge ${badgeClass}">${esc(priority)}</span>
          </div>
          <div style="color: var(--gray-600); font-weight:600; margin-bottom:10px;">
            ${esc(rec.why)}
          </div>
          <div style="color: var(--gray-700);">
            <ul style="margin-left:18px; line-height:1.6;">
              ${actions}
            </ul>
          </div>
        </div>
      `;

      coachRecs.insertAdjacentHTML('beforeend', html);
    });

    // show
    loadingEl.style.display = 'none';
    errorEl.style.display = 'none';
    contentEl.style.display = 'block';

  } catch (e) {
    console.error(e);
    loadingEl.style.display = 'none';
    errorEl.style.display = 'block';
    contentEl.style.display = 'none';
  }
});
</script>
<script>
document.addEventListener('DOMContentLoaded', async () => {
  const card = document.getElementById('analyticsCard');
  if (!card) return;

  const url = card.dataset.url;

  const loadingEl = document.getElementById('analyticsLoading');
  const errorEl = document.getElementById('analyticsError');
  const contentEl = document.getElementById('analyticsContent');

  const el = (id) => document.getElementById(id);

  function formatProg(v) {
    if (v === null || v === undefined) return '-';
    const n = Number(v);
    if (Number.isNaN(n)) return v;
    if (n > 0) return `+${n} ↑`;
    if (n < 0) return `${n} ↓`;
    return `0 →`;
  }

  function badgeForMood(h) {
    const mood = (h || '').toLowerCase();
    if (mood.includes('excellente') || mood.includes('bonne')) return 'badge-success';
    if (mood.includes('neutre')) return 'badge-warning';
    if (mood.includes('mauvaise')) return 'badge-danger';
    return 'badge-primary';
  }

  try {
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();

    if (data?.message) {
      // cas: aucun suivi
      loadingEl.style.display = 'none';
      errorEl.style.display = 'none';
      contentEl.style.display = 'block';
      contentEl.innerHTML = `<div style="padding:14px; border-radius:12px; background: var(--gray-50); border:1px solid var(--gray-200); font-weight:700; color: var(--gray-700);">
        ${data.message}
      </div>`;
      return;
    }

    // KPIs
    el('a_nbSuivis').textContent = data.nbSuivis ?? '-';
    el('a_avg').textContent = data?.scores?.avg ?? '-';
    el('a_best').textContent = data?.scores?.best ?? '-';
    el('a_worst').textContent = data?.scores?.worst ?? '-';

    el('a_last').textContent = data?.scores?.last ?? '-';
    el('a_previous').textContent = data?.scores?.previous ?? '-';
    el('a_delta').textContent = data?.scores?.delta ?? '-';

    const progEl = el('a_progression');
const prog = Number(data?.scores?.progression);

progEl.textContent = formatProg(prog);

if (prog > 0) {
  progEl.style.color = '#16a34a'; // أخضر
} else if (prog < 0) {
  progEl.style.color = '#dc2626'; // أحمر
} else {
  progEl.style.color = '#374151';
}
    el('a_completion').textContent = data?.completionRate ?? '-';

    // Indicators
    el('a_sleep').textContent = data?.indicatorsAvg?.sommeil ?? '-';
    el('a_energy').textContent = data?.indicatorsAvg?.energie ?? '-';
    el('a_stress').textContent = data?.indicatorsAvg?.stress ?? '-';
    el('a_food').textContent = data?.indicatorsAvg?.alimentation ?? '-';

    // Mood distribution chips
    const wrap = el('a_humeurWrap');
    wrap.innerHTML = '';
    (data?.humeurDistribution || []).forEach(item => {
      const mood = item.humeur ?? '—';
      const total = item.total ?? 0;
      const span = document.createElement('span');
      span.className = `badge ${badgeForMood(mood)}`;
      span.textContent = `${mood}: ${total}`;
      wrap.appendChild(span);
    });

    // show
    loadingEl.style.display = 'none';
    errorEl.style.display = 'none';
    contentEl.style.display = 'block';

  } catch (e) {
    console.error(e);
    loadingEl.style.display = 'none';
    errorEl.style.display = 'block';
    contentEl.style.display = 'none';
  }
});
</script>
