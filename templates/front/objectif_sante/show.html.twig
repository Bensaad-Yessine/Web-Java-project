                                {% if objectif_sante.statut == 'EN_COURS' %}
                                    <span class="badge badge-info">En cours</span>
                                {% elseif objectif_sante.statut == 'ATTEINT' %}
                                    <span class="badge badge-success">Atteint</span>
                                {% elseif objectif_sante.statut == 'ABANDONNE' %}
