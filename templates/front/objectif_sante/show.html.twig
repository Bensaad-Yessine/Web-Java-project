            {# ✅ ICI tu colles la carte IA Risque d’abandon #}
<div class="card">
  <div class="card-header">
    <h2 class="card-title">🤖 Risque d’abandon (IA)</h2>
  </div>

  <div class="card-content">
    {% set rp = risk.riskPercent ?? 0 %}
    {% set lvl = risk.riskLevel ?? 'LOW' %}
    {% set title = risk.messageTitle ?? 'Risque IA' %}
    {% set msg = risk.message ?? '' %}

    {% set badgeClass =
      lvl == 'HIGH' ? 'badge-danger' :
      (lvl == 'MEDIUM' ? 'badge-warning' : 'badge-success')
    %}

    <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-bottom:14px;">
      <span class="badge {{ badgeClass }}">{{ lvl }}</span>
      <span class="badge badge-primary">{{ rp }}%</span>
      <span class="badge badge-info">{{ title }}</span>
    </div>

    <div class="progress-container" style="margin: 0 0 12px 0;">
      <div class="progress-label">
        <span>Niveau de risque</span>
        <span>{{ rp }}%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style="width: {{ rp }}%;
          background: {{ lvl == 'HIGH'
            ? 'linear-gradient(90deg, var(--red-500), var(--red-600))'
            : (lvl == 'MEDIUM'
              ? 'linear-gradient(90deg, var(--orange-500), var(--orange-600))'
              : 'linear-gradient(90deg, var(--green-500), var(--green-600))'
            )
          }};">
        </div>
      </div>
    </div>

    <div style="padding:16px; border-radius: var(--radius-lg);
      background: rgba(249,250,251,0.9);
      border: 1px solid rgba(229,231,235,0.6);">
      <div style="font-weight:800; color: var(--gray-900); margin-bottom:6px;">Conseil</div>
      <div style="color: var(--gray-700); font-weight:600;">{{ msg }}</div>
    </div>
  </div>
</div>
