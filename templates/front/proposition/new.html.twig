{% extends 'user/FrontOffice.html.twig' %}

{% block title %}Nouvelle proposition - {{ groupe_projet.nomProjet }}{% endblock %}

{% block head_extra %}
<style>
    #lieu-map-wrapper { display: none; margin-top: 12px; }
    #lieu-map { width: 100%; height: 300px; border-radius: 10px; border: 2px solid #6366f1; }
    #lieu-map-close { display: block; text-align: right; font-size: 12px; color: #6b7280; cursor: pointer; margin-bottom: 4px; }
    #lieu-map-close:hover { color: #ef4444; }
</style>
{% endblock %}

{% block body %}
<main class="main">
<header class="header">
    <div>
        <h1 class="h1">Nouvelle proposition de réunion</h1>
        <p class="muted">Groupe : {{ groupe_projet.nomProjet }}</p>
    </div>
    <a href="{{ path('front_groupe_projet_show', { id: groupe_projet.id }) }}" style="padding: 12px 24px; background: white; color: var(--gray-700); text-decoration: none; border-radius: var(--radius-lg); font-weight: 600; border: 1px solid var(--gray-300); transition: all var(--transition); display: inline-flex; align-items: center; gap: 8px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Retour au groupe
    </a>
</header>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }}" style="margin-bottom: 20px; padding: 16px 20px; border-radius: 12px; background: {% if label == 'success' %}var(--green-50){% elseif label == 'error' %}var(--red-50){% else %}var(--blue-50){% endif %}; border: 1px solid {% if label == 'success' %}var(--green-200){% elseif label == 'error' %}var(--red-200){% else %}var(--blue-200){% endif %}; color: {% if label == 'success' %}var(--green-900){% elseif label == 'error' %}var(--red-900){% else %}var(--blue-900){% endif %};">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

<div class="profile-container">
    <div style="max-width: 800px; margin: 0 auto;">
        <div class="card" style="border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
            <div style="padding: 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <h2 style="margin: 0 0 4px 0; font-size: 18px;">{{ groupe_projet.nomProjet }}</h2>
                <p style="margin: 0; opacity: 0.9; font-size: 14px;">{{ groupe_projet.matiere }} · {{ groupe_projet.nbrMembre }} membre(s)</p>
            </div>
            <div class="card-content" style="padding: 24px;">
                <div id="form-errors"></div>
                {{ form_start(form, {'action': path('front_proposition_reunion_new', { id: groupe_projet.id }), 'method': 'POST', 'attr': {'id': 'propositionForm'}}) }}
                {{ form_errors(form) }}

                <div class="form-group" style="margin-bottom: 20px;">
                    {{ form_label(form.titre) }}
                    {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;'}}) }}
                    {{ form_errors(form.titre) }}
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group" style="margin-bottom: 20px;">
                        {{ form_label(form.dateReunion) }}
                        {{ form_widget(form.dateReunion, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;'}}) }}
                        {{ form_errors(form.dateReunion) }}
                    </div>
                    <div class="form-group" style="margin-bottom: 20px;">
                        {{ form_label(form.dateFinVote) }}
                        {{ form_widget(form.dateFinVote, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;'}}) }}
                        {{ form_errors(form.dateFinVote) }}
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group" style="margin-bottom: 20px; position: relative;">
                        {{ form_label(form.lieu) }}
                        {# Champ Symfony réel (caché) - recevra adresse||lat,lng au submit #}
                        {{ form_widget(form.lieu, {'attr': {'id': 'lieu-symfony-input', 'type': 'hidden', 'style': 'display:none;'}}) }}
                        {# Champ visible pour l'utilisateur #}
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <div style="flex: 1;">
                                <input type="text" id="lieu-display" autocomplete="off" class="form-control"
                                    style="width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;"
                                    placeholder="Tapez un lieu ou cliquez sur la carte...">
                            </div>
                            <button type="button" id="btn-open-map" style="white-space: nowrap; padding: 12px 14px; border: 1px solid #6366f1; background: #6366f1; color:white; border-radius: var(--radius); font-size: 13px; cursor: pointer; font-weight:600;">
                                🗺 Carte
                            </button>
                            <button type="button" id="lieu-use-my-position" style="white-space: nowrap; padding: 12px 14px; border: 1px solid var(--gray-300); background: white; border-radius: var(--radius); font-size: 13px; cursor: pointer;">Ma position</button>
                        </div>
                        {{ form_errors(form.lieu) }}
                        <div id="lieu-map-wrapper" style="display:none; margin-top: 12px;">
                            <span id="lieu-map-close" style="display: block; text-align: right; font-size: 12px; color: #6b7280; cursor: pointer; margin-bottom: 4px;">✕ Fermer la carte</span>
                            <div id="lieu-map" style="width: 100%; height: 300px; border-radius: 10px; border: 2px solid #6366f1;"></div>
                            <p style="margin-top:6px; font-size:12px; color:#6b7280;">Cliquez sur la carte pour choisir votre lieu.</p>
                        </div>
                        <p id="lieu-status" style="margin-top: 6px; font-size: 12px; color: #059669; font-weight:600;"></p>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group" style="margin-bottom: 20px;">
                        {{ form_label(form.heureDebut) }}
                        {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;'}}) }}
                        {{ form_errors(form.heureDebut) }}
                    </div>
                    <div class="form-group" style="margin-bottom: 20px;">
                        {{ form_label(form.heureFin) }}
                        {{ form_widget(form.heureFin, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;'}}) }}
                        {{ form_errors(form.heureFin) }}
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 20px;">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px; min-height: 120px; resize: vertical;', 'rows': 5}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="form-group" style="margin-bottom: 24px;">
                    {{ form_label(form.status) }}
                    {{ form_widget(form.status, {'attr': {'class': 'form-control', 'style': 'width: 100%; padding: 14px 18px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 15px;'}}) }}
                    {{ form_errors(form.status) }}
                </div>

                <div style="display: flex; gap: 12px; margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--gray-200); flex-wrap: wrap;">
                    <button type="submit" style="flex: 1; min-width: 200px; padding: 16px; background: linear-gradient(135deg, var(--green-500), var(--green-600)); color: white; border: none; border-radius: var(--radius-lg); font-weight: 700; font-size: 16px; cursor: pointer; transition: all var(--transition); box-shadow: var(--shadow-sm); display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                        </svg>
                        Créer la proposition
                    </button>
                    <a href="{{ path('front_groupe_projet_show', { id: groupe_projet.id }) }}" style="padding: 16px 24px; background: white; color: var(--gray-700); text-decoration: none; border: 1px solid var(--gray-300); border-radius: var(--radius-lg); font-weight: 600; font-size: 16px; transition: all var(--transition); display: inline-flex; align-items: center; justify-content: center; gap: 10px;">
                        Annuler
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<script>
    var _gMap = null, _gMarker = null, _gGeocoder = null, _gAutocomplete = null;
    var _mapsReady = false;
    var _selLat = null, _selLng = null, _selAddr = '';

    window.initGoogleMaps = function () {
        _mapsReady = true;
        _gGeocoder = new google.maps.Geocoder();
        var displayInput = document.getElementById('lieu-display');
        if (displayInput) {
            _gAutocomplete = new google.maps.places.Autocomplete(displayInput, { types: ['geocode'] });
            _gAutocomplete.addListener('place_changed', function () {
                var place = _gAutocomplete.getPlace();
                if (place && place.geometry) {
                    var lat = place.geometry.location.lat();
                    var lng = place.geometry.location.lng();
                    var addr = place.formatted_address || place.name || displayInput.value || '';
                    _openMap(lat, lng);
                    _saveLocation(addr, lat, lng);
                }
            });
        }
    };

    function _openMap(lat, lng) {
        var wrapper = document.getElementById('lieu-map-wrapper');
        var mapDiv  = document.getElementById('lieu-map');
        if (!wrapper || !mapDiv) return;
        wrapper.style.display = 'block';
        if (!_gMap) {
            _gMap = new google.maps.Map(mapDiv, {
                center: { lat: lat, lng: lng }, zoom: 15,
                mapTypeControl: false, streetViewControl: false,
                fullscreenControl: false, clickableIcons: false
            });
            _gMap.addListener('click', function (e) {
                _placeMarker(e.latLng.lat(), e.latLng.lng());
                _reverseGeocode(e.latLng.lat(), e.latLng.lng());
            });
        } else {
            _gMap.setCenter({ lat: lat, lng: lng });
            _gMap.setZoom(15);
        }
        _placeMarker(lat, lng);
    }

    function _placeMarker(lat, lng) {
        if (!_gMap) return;
        if (_gMarker) _gMarker.setMap(null);
        _gMarker = new google.maps.Marker({ position: { lat: lat, lng: lng }, map: _gMap, animation: google.maps.Animation.DROP });
    }

    function _saveLocation(addr, lat, lng) {
        _selLat = lat; _selLng = lng; _selAddr = addr || '';
        var displayInput = document.getElementById('lieu-display');
        if (displayInput) displayInput.value = _selAddr || (lat.toFixed(6) + ', ' + lng.toFixed(6));
        var hiddenInput = document.getElementById('lieu-symfony-input');
        if (hiddenInput) {
            var coordStr = lat.toFixed(6) + ',' + lng.toFixed(6);
            hiddenInput.value = _selAddr ? (_selAddr + '||' + coordStr) : coordStr;
        }
        var statusEl = document.getElementById('lieu-status');
        if (statusEl) statusEl.textContent = '✅ Lieu enregistré : ' + (_selAddr || lat.toFixed(6) + ', ' + lng.toFixed(6));
    }

    function _reverseGeocode(lat, lng) {
        if (_gGeocoder) {
            _gGeocoder.geocode({ location: { lat: lat, lng: lng } }, function (results, status) {
                if (status === 'OK' && results[0]) _saveLocation(results[0].formatted_address, lat, lng);
                else _saveLocation('', lat, lng);
            });
        } else {
            _saveLocation('', lat, lng);
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Pré-remplir lieu-display depuis lieu-symfony-input (si rechargement après erreur Symfony)
        var hiddenInit  = document.getElementById('lieu-symfony-input');
        var displayInit = document.getElementById('lieu-display');
        if (hiddenInit && displayInit && hiddenInit.value && !displayInit.value) {
            var initVal = hiddenInit.value;
            displayInit.value = initVal.indexOf('||') !== -1 ? initVal.split('||')[0].trim() : initVal;
        }

        var openMapBtn = document.getElementById('btn-open-map');
        var locateBtn  = document.getElementById('lieu-use-my-position');
        var closeBtn   = document.getElementById('lieu-map-close');

        if (openMapBtn) {
            openMapBtn.addEventListener('click', function () {
                if (!_mapsReady) { alert('Google Maps est en cours de chargement...'); return; }
                _openMap(_selLat !== null ? _selLat : 36.8065, _selLng !== null ? _selLng : 10.1815);
            });
        }

        if (locateBtn) {
            locateBtn.addEventListener('click', function () {
                if (!_mapsReady) { alert('Google Maps est en cours de chargement...'); return; }
                if (!navigator.geolocation) { _openMap(36.8065, 10.1815); return; }
                locateBtn.disabled = true; locateBtn.textContent = '...';
                navigator.geolocation.getCurrentPosition(
                    function (pos) {
                        locateBtn.disabled = false; locateBtn.textContent = 'Ma position';
                        _openMap(pos.coords.latitude, pos.coords.longitude);
                        _reverseGeocode(pos.coords.latitude, pos.coords.longitude);
                    },
                    function () { locateBtn.disabled = false; locateBtn.textContent = 'Ma position'; _openMap(36.8065, 10.1815); },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
                );
            });
        }

        if (closeBtn) {
            closeBtn.addEventListener('click', function () { document.getElementById('lieu-map-wrapper').style.display = 'none'; });
        }

        // Synchronisation en temps réel : quand l'utilisateur tape dans lieu-display,
        // on met à jour directement le champ Symfony caché
        var displayInputSync = document.getElementById('lieu-display');
        var hiddenInputSync  = document.getElementById('lieu-symfony-input');
        if (displayInputSync && hiddenInputSync) {
            displayInputSync.addEventListener('input', function () {
                if (_selLat === null) {
                    hiddenInputSync.value = displayInputSync.value.trim();
                }
            });
        }

        var form = document.getElementById('propositionForm');
        if (!form) return;

        form.addEventListener('submit', function (e) {
            // Synchroniser lieu-display → lieu-symfony-input si pas de coordonnées carte
            var hiddenInput  = document.getElementById('lieu-symfony-input');
            var displayInput = document.getElementById('lieu-display');
            if (hiddenInput && _selLat === null && displayInput && displayInput.value.trim()) {
                hiddenInput.value = displayInput.value.trim();
            }

            // Validation dates
            var dateField    = form.querySelector('input[name="proposition_reunion[dateReunion]"]');
            var voteEndField = form.querySelector('input[name="proposition_reunion[dateFinVote]"]');
            var startField   = form.querySelector('input[name="proposition_reunion[heureDebut]"]');
            var endField     = form.querySelector('input[name="proposition_reunion[heureFin]"]');
            if (!dateField || !startField || !endField) return;

            var dateVal = dateField.value, startVal = startField.value, endVal = endField.value;
            if (!dateVal || !startVal || !endVal) return;

            var dp = dateVal.split('-').map(Number), sp = startVal.split(':').map(Number), ep = endVal.split(':').map(Number);
            var start = new Date(dp[0], dp[1]-1, dp[2], sp[0], sp[1], 0);
            var end   = new Date(dp[0], dp[1]-1, dp[2], ep[0], ep[1], 0);
            var now   = new Date();
            var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            var dateOnly = new Date(dp[0], dp[1]-1, dp[2]);

            var errors = [];
            var errorContainer = document.getElementById('form-errors');
            if (errorContainer) errorContainer.innerHTML = '';

            if (dateOnly < today) errors.push('La date ne peut pas être dans le passé.');
            var voteEndVal = voteEndField ? voteEndField.value : '';
            if (voteEndVal && new Date(voteEndVal) < now) errors.push('La fin du vote doit être dans le futur.');
            if (dateOnly.getTime() === today.getTime() && start < new Date(now.getTime() + 3600000)) {
                errors.push("Pour aujourd'hui, l'heure de début doit être au moins +1h.");
            }
            var endForDiff = end <= start ? new Date(end.getTime() + 86400000) : end;
            var diffMin = Math.round((endForDiff - start) / 60000);
            if (diffMin <= 0) errors.push("L'heure de fin doit être après l'heure de début.");
            else {
                if (diffMin < 30)  errors.push('La durée doit être au moins de 30 minutes.');
                if (diffMin > 300) errors.push('La durée maximale est de 5 heures.');
            }

            if (errors.length) {
                e.preventDefault();
                if (errorContainer) {
                    errorContainer.innerHTML = '<div class="alert alert-danger">' + errors.join('<br>') + '</div>';
                    errorContainer.scrollIntoView({ behavior: 'smooth' });
                } else {
                    alert(errors.join('\n'));
                }
            }
        });
    });
</script>
<script src="https://maps.googleapis.com/maps/api/js?key={{ google_maps_api_key }}&libraries=places&callback=initGoogleMaps" async defer></script>
</main>
{% endblock %}
