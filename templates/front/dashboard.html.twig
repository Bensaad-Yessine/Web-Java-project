{% extends 'front/base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Tableau de bord</h1>
        <p class="page-subtitle text-muted">Bienvenue sur votre espace</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card p-3 shadow-sm bg-white rounded-lg">
            <div class="d-flex align-items-center">
                <i class="mdi mdi-home-outline mdi-24px me-2 text-primary"></i>
                <div>
                    <h3 class="mb-0">{{ totalSalles }}</h3>
                    <small>Salles</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 shadow-sm bg-white rounded-lg">
            <div class="d-flex align-items-center">
                <i class="mdi mdi-calendar-clock mdi-24px me-2 text-success"></i>
                <div>
                    <h3 class="mb-0">{{ totalSeances }}</h3>
                    <small>Séances</small>
                </div>
            </div>
        </div>
    </div>
    {% if nextSeance %}
    <div class="col-md-6">
        <div class="card p-3 shadow-sm bg-white rounded-lg">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <i class="mdi mdi-clock-outline mdi-24px me-2 text-warning"></i>
                    <h5 class="mb-0">Prochaine séance</h5>
                    <small class="text-muted">
                        {{ nextSeance.debut|date('d/m/Y H:i') }} – {{ nextSeance.seanceFin|date('H:i') }}<br>
                        Salle {{ nextSeance.salle.name }}
                    </small>
                </div>
                <a href="{{ path('front_salles') }}" class="btn btn-sm btn-outline-primary">Voir salles</a>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<h4 class="mb-3">Dernières salles</h4>
<table class="table table-hover">
    <thead>
        <tr><th>ID</th><th>Nom</th><th>Bloc</th><th>Étage</th></tr>
    </thead>
    <tbody>
        {% for salle in recentSalles %}
            <tr>
                <td>{{ salle.id }}</td>
                <td>{{ salle.name }}</td>
                <td>{{ salle.block }}</td>
                <td>{{ salle.etage }}</td>
            </tr>
        {% else %}
            <tr><td colspan="4">Aucune salle</td></tr>
        {% endfor %}
    </tbody>
</table>
<a href="{{ path('front_salles') }}" class="btn btn-sm btn-outline-secondary mt-2">Voir toutes les salles</a>
{% endblock %}
