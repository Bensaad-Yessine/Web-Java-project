{% extends 'front/base.html.twig' %}

{% block title %}Séances{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Séances <span class="badge bg-secondary ms-2">{{ seances|length }}</span></h1>
        <p class="page-subtitle text-muted">Liste des séances programmées</p>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Salle</th>
                <th>Objectif</th>
            </tr>
        </thead>
        <tbody>
            {% for seance in seances %}
                <tr>
                    <td>{{ seance.debut|date('d/m/Y') }}</td>
                    <td>{{ seance.debut|date('H:i') }}</td>
                    <td>{{ seance.seanceFin|date('H:i') }}</td>
                    <td>{{ seance.salle ? seance.salle.name : 'N/A' }}</td>
                    <td>{{ seance.objectif ? seance.objectif.name : "" }}</td>
                </tr>
            {% else %}
                <tr><td colspan="5">Aucune séance</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}