<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Mon historique de présences – ESPRIT</title>

    <link rel="stylesheet" href="{{ asset('assets/vendors/mdi/css/materialdesignicons.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendors/css/vendor.bundle.base.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">

    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .hist-page { max-width: 820px; margin: 30px auto; padding: 0 16px 40px; }

        .hist-header {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 18px; padding: 26px 30px; color: #fff; margin-bottom: 24px;
        }
        .hist-header h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 4px; }
        .hist-header p  { margin: 0; opacity: .8; font-size: .9rem; }

        .stat-mini {
            display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;
        }
        .sm-card {
            flex: 1; min-width: 130px;
            background: #fff; border-radius: 12px; padding: 16px 18px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05); text-align: center;
        }
        .sm-card .num { font-size: 1.8rem; font-weight: 800; }
        .sm-card .lbl { font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; color: #888; }
        .sm-card.present .num { color: #2e7d32; }
        .sm-card.late    .num { color: #e65100; }
        .sm-card.absent  .num { color: #c62828; }

        .card { background: #fff; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }
        table { width: 100%; border-collapse: collapse; }
        th { background: #f8f9ff; padding: 12px 16px; text-align: left; font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; color: #888; border-bottom: 1px solid #eee; }
        td { padding: 13px 16px; font-size: .88rem; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #fafbff; }

        .status-badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 12px; border-radius: 50px; font-size: .78rem; font-weight: 700;
        }
        .sb-PRESENT  { background: #e8f5e9; color: #2e7d32; }
        .sb-LATE     { background: #fff3e0; color: #e65100; }
        .sb-ABSENT   { background: #ffebee; color: #c62828; }
        .sb-REJECTED { background: #fce4ec; color: #880e4f; }

        .empty-state { padding: 50px; text-align: center; color: #aaa; }
        .empty-state .icon { font-size: 3rem; margin-bottom: 10px; display: block; }

        .scan-link {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 24px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff; text-decoration: none;
            border-radius: 50px; font-weight: 600; font-size: .9rem;
            margin-bottom: 24px;
        }
    </style>
</head>
<body>
<div class="hist-page">

    <div class="hist-header">
        <h1><i class="mdi mdi-history"></i> Mon historique de présences</h1>
        <p>{{ app.user ? app.user.fullName : '' }} – {{ app.user ? app.user.email : '' }}</p>
    </div>

    <a href="{{ path('app_attendance_scan_page') }}" class="scan-link">
        <i class="mdi mdi-qrcode-scan"></i> Scanner un QR Code
    </a>

    {% set cntPresent = 0 %}
    {% set cntLate    = 0 %}
    {% set cntAbsent  = 0 %}
    {% for a in attendances %}
        {% if a.status == 'PRESENT' %}    {% set cntPresent = cntPresent + 1 %}
        {% elseif a.status == 'LATE' %}   {% set cntLate = cntLate + 1 %}
        {% else %}                        {% set cntAbsent = cntAbsent + 1 %}
        {% endif %}
    {% endfor %}

    <div class="stat-mini">
        <div class="sm-card"><div class="num">{{ attendances|length }}</div><div class="lbl">Total</div></div>
        <div class="sm-card present"><div class="num">{{ cntPresent }}</div><div class="lbl">Présent</div></div>
        <div class="sm-card late">   <div class="num">{{ cntLate }}</div>   <div class="lbl">Retard</div></div>
        <div class="sm-card absent"> <div class="num">{{ cntAbsent }}</div> <div class="lbl">Absent</div></div>
    </div>

    <div class="card">
        {% if attendances is empty %}
            <div class="empty-state">
                <span class="icon">📋</span>
                <p>Aucun historique de présence</p>
            </div>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>Matière</th>
                        <th>Salle</th>
                        <th>Date &amp; Heure</th>
                        <th>Statut</th>
                        <th>Retard</th>
                    </tr>
                </thead>
                <tbody>
                    {% for a in attendances %}
                    <tr>
                        <td style="font-weight:600;">
                            {{ a.seance and a.seance.matiere ? a.seance.matiere.nom : '–' }}
                        </td>
                        <td>{{ a.seance and a.seance.salle ? a.seance.salle.name : '–' }}</td>
                        <td>
                            {{ a.seance and a.seance.heureDebut ? a.seance.heureDebut|date('d/m/Y H:i') : '–' }}
                            {% if a.scannedAt %}
                                <div style="font-size:.75rem;color:#aaa;">Scanné : {{ a.scannedAt|date('H:i:s') }}</div>
                            {% endif %}
                        </td>
                        <td><span class="status-badge sb-{{ a.status }}">{{ a.status }}</span></td>
                        <td>{% if a.minutesLate %}{{ a.minutesLate }} min{% else %}–{% endif %}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
</body>
</html>
