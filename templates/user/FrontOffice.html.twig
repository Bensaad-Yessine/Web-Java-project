            overflow-y: auto;
            background: var(--gray-50);
        }

        .conversations-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .conversation-item {
            padding: 12px 16px;
            border-bottom: 1px solid var(--gray-200);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all var(--transition);
            background: white;
        }

        .conversation-item:hover {
            background: var(--gray-50);
        }

        .conversation-item.unread {
            background: rgba(139, 92, 246, 0.05);
            border-left: 3px solid #8b5cf6;
            padding-left: 13px;
        }

        .conversation-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            flex-shrink: 0;
        }

        .conversation-info {
            flex: 1;
            min-width: 0;
        }

        .conversation-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--gray-800);
            margin-bottom: 4px;
        }

        .conversation-message {
            font-size: 13px;
            color: var(--gray-600);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .conversation-badge {
            background: #8b5cf6;
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 600;
        }

        .empty-conversations {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--gray-500);
            font-size: 14px;
        }

        .chat-header-messaging {
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            color: white;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--gray-200);
        }

        .back-to-convs {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            font-size: 16px;
            padding: 0;
        }

        .back-to-convs:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        #chat-title {
            flex: 1;
            margin: 0;
            font-size: 16px;
            font-weight: 700;
        }

        .messages-area {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            background: var(--gray-50);
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .message {
            display: flex;
            flex-direction: column;
            gap: 4px;
            animation: message-fade 0.3s ease-out;
        }

        .message.own {
            align-items: flex-end;
        }

        .message.other {
            align-items: flex-start;
        }

        .message-bubble {
            max-width: 70%;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.4;
            word-wrap: break-word;
        }

        .message.own .message-bubble {
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            color: white;
            border-radius: 12px 12px 4px 12px;
        }

        .message.other .message-bubble {
            background: white;
            color: var(--gray-800);
            border: 1px solid var(--gray-200);
            border-radius: 12px 12px 12px 4px;
        }

        .message-time {
            font-size: 11px;
            color: var(--gray-500);
            margin-top: 2px;
            padding: 0 4px;
        }

        .message-meta {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            color: var(--gray-500);
        }

        .message-status {
            font-weight: 600;
            color: var(--gray-600);
        }

        .message-actions {
            display: flex;
            gap: 6px;
            opacity: 0;
            transition: opacity var(--transition);
        }

        .message.own:hover .message-actions {
            opacity: 1;
        }

        .message-action-btn {
            border: none;
            background: var(--gray-100);
            color: var(--gray-700);
            border-radius: 6px;
            padding: 3px 6px;
            font-size: 11px;
            cursor: pointer;
            transition: all var(--transition);
        }

        .message-action-btn:hover {
            background: var(--gray-200);
        }

        .message-input-area {
            padding: 12px 16px;
            background: white;
            border-top: 1px solid var(--gray-200);
            display: flex;
            gap: 8px;
        }

        #message-input {
            flex: 1;
            border: 1px solid var(--gray-300);
            border-radius: 20px;
            padding: 10px 14px;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            transition: all var(--transition);
        }

        #message-input:focus {
            border-color: #8b5cf6;
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
        }

        .send-btn {
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            color: white;
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            font-weight: 600;
        }

        .send-btn:hover:not(:disabled) {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(139, 92, 246, 0.4);
        }

        .send-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .conversations-container::-webkit-scrollbar,
        .messages-area::-webkit-scrollbar,
        .search-results::-webkit-scrollbar {
            width: 6px;
        }

        .conversations-container::-webkit-scrollbar-track,
        .messages-area::-webkit-scrollbar-track,
        .search-results::-webkit-scrollbar-track {
            background: var(--gray-100);
        }

        .conversations-container::-webkit-scrollbar-thumb,
        .messages-area::-webkit-scrollbar-thumb,
        .search-results::-webkit-scrollbar-thumb {
            background: var(--gray-300);
            border-radius: 3px;
        }

        .conversations-container::-webkit-scrollbar-thumb:hover,
        .messages-area::-webkit-scrollbar-thumb:hover,
        .search-results::-webkit-scrollbar-thumb:hover {
            background: var(--gray-400);
        }

        /* AI Chatbot Widget Styles */
        #ai-chat-button {
            position: fixed;
            bottom: 90px;
            right: 20px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            transition: all var(--transition);
            z-index: 999;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        #ai-chat-button:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(79, 70, 229, 0.6);
            border-color: rgba(255, 255, 255, 0.5);
        }

        .ai-chat-widget {
            position: fixed;
            bottom: 160px;
            right: 20px;
            width: 400px;
            max-width: 90vw;
            max-height: 550px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px -20px rgba(0, 0, 0, 0.3), 0 0 30px rgba(79, 70, 229, 0.15);
            display: none;
            flex-direction: column;
            overflow: hidden;
            z-index: 998;
            animation: ai-widget-slide-up 0.3s ease-out;
            border: 1px solid rgba(79, 70, 229, 0.2);
        }

        .ai-chat-widget.active {
            display: flex;
        }

        @keyframes ai-widget-slide-up {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .ai-chat-header {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            padding: 16px 20px;
            border-bottom: 1px solid var(--gray-200);
            position: relative;
        }

        .ai-chat-header h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
        }

        .ai-chat-close {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            font-size: 16px;
            padding: 0;
        }

        .ai-chat-close:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        .ai-messages-area {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            background: linear-gradient(to bottom, rgba(79, 70, 229, 0.02), rgba(124, 58, 237, 0.02));
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .ai-message {
            display: flex;
            flex-direction: column;
            gap: 4px;
            animation: message-fade 0.3s ease-out;
        }

        .ai-message.user {
            align-items: flex-end;
        }

        .ai-message.ai {
            align-items: flex-start;
        }

        .ai-message-bubble {
            max-width: 80%;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.5;
            word-wrap: break-word;
        }

        .ai-message.user .ai-message-bubble {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            border-radius: 12px 12px 4px 12px;
            box-shadow: 0 2px 8px rgba(79, 70, 229, 0.2);
        }

        .ai-message.ai .ai-message-bubble {
            background: white;
            color: var(--gray-800);
            border: 1px solid var(--gray-200);
            border-radius: 12px 12px 12px 4px;
        }

        .ai-messages-area::-webkit-scrollbar {
            width: 6px;
        }

        .ai-messages-area::-webkit-scrollbar-track {
            background: var(--gray-100);
        }

        .ai-messages-area::-webkit-scrollbar-thumb {
            background: var(--gray-300);
            border-radius: 3px;
        }

        .ai-messages-area::-webkit-scrollbar-thumb:hover {
            background: var(--gray-400);
        }

        .ai-message-input-area {
            padding: 12px 16px;
            background: white;
            border-top: 1px solid var(--gray-200);
            display: flex;
            gap: 8px;
        }

        #ai-message-input {
            flex: 1;
            border: 1px solid var(--gray-300);
            border-radius: 20px;
            padding: 10px 14px;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            transition: all var(--transition);
        }

        #ai-message-input:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }

        .ai-send-btn {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            font-weight: 600;
            flex-shrink: 0;
        }

        .ai-send-btn:hover:not(:disabled) {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4);
        }

        .ai-send-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .ai-typing-indicator {
            display: flex;
            gap: 4px;
            padding: 12px 16px;
            align-items: center;
        }

        .ai-typing-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #4f46e5;
            animation: typing-bounce 1.4s infinite;
        }

        .ai-typing-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .ai-typing-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes typing-bounce {
            0%, 60%, 100% {
                opacity: 0.3;
                transform: translateY(0);
            }
            30% {
                opacity: 1;
                transform: translateY(-8px);
            }
        }

        @keyframes message-fade {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
