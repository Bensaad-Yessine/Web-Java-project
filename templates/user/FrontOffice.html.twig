                <div class="stat-card">
                    <div class="stat-value">{{ stats.tasks.completed }}</div>
                    <div class="stat-label">✅ Complétées</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.tasks.pending }}</div>
                    <div class="stat-label">⏳ En attente</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.tasks.highPriority }}</div>
                    <div class="stat-label">🚨 Haute priorité</div>
                </div>

                <!-- Health Objectives Statistics -->
                <div class="stat-card">
                    <div class="stat-value">{{ stats.objectifs_sante.total }}</div>
                    <div class="stat-label">🏥 Objectifs Santé</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.objectifs_sante.active }}</div>
                    <div class="stat-label">🌟 Actifs</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.objectifs_sante.completed }}</div>
                    <div class="stat-label">🎯 Complétés</div>
                </div>

                <!-- Wellbeing Tracking Statistics -->
                <div class="stat-card">
                    <div class="stat-value">{{ stats.suivi_bien_etre.total }}</div>
                    <div class="stat-label">😊 Suivi Bien-être</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.suivi_bien_etre.this_month }}</div>
                    <div class="stat-label">📆 Ce mois-ci</div>
                </div>

                <!-- Project Groups Statistics -->
                <div class="stat-card">
                    <div class="stat-value">{{ stats.groupes_projets.total }}</div>
                    <div class="stat-label">👥 Groupes Projets</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.groupes_projets.active }}</div>
                    <div class="stat-label">💼 Actifs</div>
                </div>

                <!-- Alert Preferences Statistics -->
                <div class="stat-card">
                    <div class="stat-value">{{ stats.preferences_alertes.total }}</div>
                    <div class="stat-label">🔔 Préférences Alertes</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ stats.preferences_alertes.active }}</div>
                    <div class="stat-label">✔️ Activées</div>
                </div>
            </div>

            <div class="tasks-container">
                <div class="tasks-header">
                    <h2 class="tasks-title">Toutes les tâches ({{ stats.tasks.total }})</h2>
                </div>

                <div class="task-grid" id="taskList">
                    {% if tasks is not empty %}
                        {% for task in tasks %}
                            {% set taskType = task.type|default('personnel') %}
                            {% set taskPriority = task.priorite|default('MOYEN') %}
                            {% set rawStatus = task.statut|default('A_FAIRE') %}
                            {% set isCompleted = rawStatus == 'TERMINE' %}
                            {% set statusLabels = {'A_FAIRE': 'En attente', 'EN_COURS': 'En cours', 'TERMINE': 'Terminée', 'EN_RETARD': 'En retard', 'PAUSED': 'En pause'} %}
                            {% set statusSlugMap = {'A_FAIRE':'pending', 'EN_COURS':'in_progress', 'TERMINE':'completed', 'EN_RETARD':'overdue', 'PAUSED':'paused'} %}
                            {% set statusSlug = statusSlugMap[rawStatus]|default('pending') %}
                            {% set priorityMap = {'ELEVEE': 'high', 'MOYEN': 'medium', 'FAIBLE': 'low'} %}
                            {% set priorityClassMap = {'ELEVEE': 'high', 'MOYEN': 'medium', 'FAIBLE': 'low'} %}
                            {% set priorityLabelMap = {'ELEVEE': 'Haute', 'MOYEN': 'Moyenne', 'FAIBLE': 'Basse'} %}
                            {% set priorityClass = priorityClassMap[taskPriority]|default('medium') %}
                            
                            <div class="task-card {{ isCompleted ? 'completed' : '' }} {{ priorityClass }}-priority">
                                <div class="task-header">
                                    <h3 class="task-title">{{ task.titre|default('Tâche sans titre') }}</h3>
                                    <span class="task-status status-{{ statusSlug }}">
                                        {{ statusLabels[rawStatus]|default('En attente') }}
                                    </span>
                                </div>
                                
                                {% if task.description %}
                                <div class="task-description">
                                    {{ task.description }}
                                </div>
                                {% endif %}
                                
                                <div class="task-details">
                                    <div class="detail-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M12 8v4l3 3"/>
                                            <circle cx="12" cy="12" r="10"/>
                                        </svg>
                                        <span>Priorité : 
                                            <strong style="color: 
                                                {% if priorityClass == 'high' %}var(--primary-red)
                                                {% elseif priorityClass == 'medium' %}var(--warning)
                                                {% else %}var(--secondary){% endif %}">
                                                {{ priorityLabelMap[taskPriority] }}
                                            </strong>
                                        </span>
                                    </div>
                                    
                                    {% if task.dateEcheance %}
                                    <div class="detail-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                            <line x1="16" y1="2" x2="16" y2="6"/>
                                            <line x1="8" y1="2" x2="8" y2="6"/>
                                            <line x1="3" y1="10" x2="21" y2="10"/>
                                        </svg>
                                        <span>Échéance : <strong>{{ task.dateEcheance|date('d/m/Y') }}</strong></span>
                                    </div>
                                    {% endif %}
                                    
                                    {% if task.createdAt %}
                                    <div class="detail-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                            <circle cx="12" cy="7" r="4"/>
                                        </svg>
                                        <span>Créée le : {{ task.createdAt|date('d/m/Y') }}</span>
                                    </div>
                                    {% endif %}
                                </div>
                                
                                <div class="task-tags">
                                    <span class="task-tag tag-type-{{ taskType }}">
                                        {{ taskType|capitalize }}
                                    </span>
                                </div>
                                
                                <div class="task-footer">
                                    <div class="task-actions">
                                        <a class="action-btn primary" href="{{ path('app_task_show', {'id': task.id}) }}">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10"/>
                                                <path d="M12 16v-4"/>
                                                <circle cx="12" cy="8" r="0.5" fill="currentColor" stroke="none"/>
                                            </svg>
                                            Voir détails
                                        </a>
                                        <a class="action-btn" href="{{ path('app_tache_edit', {'id': task.id}) }}">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                            Modifier
                                        </a>
                                    </div>
                                    <div class="task-date">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        {{ task.updatedAt ? 'Modifiée' : 'Créée' }} le {{ (task.updatedAt ?? task.createdAt ?? "now")|date('d/m/Y') }}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 11l3 3 8-8"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                            </svg>
                            <h3>Aucune tâche pour le moment</h3>
                            <p>Créez votre première tâche pour commencer à organiser votre travail</p>
                            <a href="{{ path('app_tache_new') }}" class="btn" style="margin-top: 20px;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 5v14M5 12h14"/>
                                </svg>
                                Créer une tâche
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="footer">
                <p>ESPRIT Assistant Étudiant • © {{ "now"|date("Y") }} • Tous droits réservés</p>
            </div>
        </main>
    </div>

    <!-- Floating notification dropdown -->
    <div id="notif-dropdown" class="dropdown hidden">
        <div class="dropdown-header">
            <h3>🔔 Notifications</h3>
            <button class="mark-all-read" id="mark-all-read">Marquer comme lues</button>
        </div>
        <ul id="notif-list"></ul>
    </div>

    <!-- Toast message -->
    <div id="toast-message" style="position: fixed; bottom: 20px; right: 20px; background: #333; color: white; padding: 12px 20px; border-radius: 8px; opacity: 0; transition: opacity 0.3s; z-index: 10000; font-size: 14px;"></div>

    <!-- Messaging Widget (Messenger-like) -->
    <button id="messaging-button" title="Messages">
        💬
        <span id="messaging-badge" style="display: none;">0</span>
    </button>
    <div id="messaging-widget">
        <div id="messaging-view">
            <!-- Search Section -->
            <div class="messaging-header">
                <h3>Messages</h3>
                <button class="messaging-close" onclick="toggleMessaging()">✕</button>
            </div>
            <div class="messaging-search">
                <input 
                    id="student-search" 
                    type="text" 
                    placeholder="Rechercher un étudiant..."
                    autocomplete="off"
                />
                <div id="search-results" class="search-results" style="display: none;"></div>
            </div>
            
            <!-- Conversations List -->
            <div class="conversations-container">
                <ul id="conversations-list" class="conversations-list"></ul>
                <div id="no-conversations" class="empty-conversations" style="display: none;">
                    <p>Aucune conversation pour le moment</p>
                </div>
            </div>
        </div>
        
        <!-- Chat View -->
        <div id="chat-view" style="display: none;">
            <div class="chat-header-messaging">
                <button class="back-to-convs" onclick="backToConversations()" title="Retour">← </button>
                <h3 id="chat-title">Conversation</h3>
                <button class="messaging-close" onclick="toggleMessaging()">✕</button>
            </div>
            <div id="messages-area" class="messages-area"></div>
            <div class="message-input-area">
                <input 
                    id="message-input" 
                    type="text" 
                    placeholder="Écrivez un message..."
                    autocomplete="off"
                />
                <button id="send-message-btn" class="send-btn" onclick="sendMessage()">↑</button>
            </div>
        </div>
    </div>

    <!-- AI Education Chatbot Widget (Llama 3.1 via Ollama) -->
    <button id="ai-chat-button" title="Assistance IA (Éducation)">
        🤖
    </button>
    <div id="ai-chat-widget" class="ai-chat-widget">
        <div class="ai-chat-header">
            <h3>Assistant IA 🤖</h3>
            <p style="font-size: 11px; color: rgba(255,255,255,0.8); margin: 4px 0 0 0;">Questions sur l'éducation & sujets</p>
            <button class="ai-chat-close" onclick="toggleAIChat()">✕</button>
        </div>
        <div id="ai-messages-area" class="ai-messages-area"></div>
        <div class="ai-message-input-area">
            <input 
                id="ai-message-input" 
                type="text" 
                placeholder="Posez une question..."
                autocomplete="off"
            />
            <button id="ai-send-btn" class="ai-send-btn" onclick="sendAIMessage()">↑</button>
        </div>
    </div>

    <script>
        // Toast helper
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast-message');
            toast.textContent = message;
            toast.style.background = type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#333';
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 3000);
        }

        // Notification system
        const notifBtn = document.getElementById('notif-btn');
        const notifDropdown = document.getElementById('notif-dropdown');
        const notifList = document.getElementById('notif-list');
        const notifBadge = document.getElementById('notif-badge');

        notifBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            notifDropdown.classList.toggle('hidden');
            if (!notifDropdown.classList.contains('hidden')) {
                positionDropdown(notifDropdown, notifBtn);
                fetchNotifications();
            }
        });

        document.addEventListener('click', function(e) {
            if (!notifDropdown.contains(e.target) && e.target !== notifBtn) {
                notifDropdown.classList.add('hidden');
            }
        });

        function positionDropdown(dropdown, button) {
            const rect = button.getBoundingClientRect();
            dropdown.style.top = (rect.bottom + 10) + 'px';
            dropdown.style.right = (window.innerWidth - rect.right) + 'px';
        }

        function fetchNotifications() {
            fetch('{{ path('notifications_fetch') }}')
                .then(response => response.json())
                .then(data => {
                    notifList.innerHTML = '';
                    if (data && data.length > 0) {
                        notifBadge.textContent = data.length;
                        notifBadge.style.display = 'flex';
                        data.forEach(notif => {
                            const li = document.createElement('li');
                            if (!notif.isRead) li.classList.add('unread');
                            li.innerHTML = `
                                <div class="message">${notif.message}</div>
                                <div class="meta">
                                    <span class="time">${notif.createdAt}</span>
                                </div>
                                <div class="notif-actions">
                                    <button class="notif-action-btn primary" onclick="markAsRead(${notif.id})">Marquer comme lue</button>
                                </div>
                            `;
                            notifList.appendChild(li);
                        });
                    } else {
                        notifBadge.style.display = 'none';
                        notifList.innerHTML = '<li style="text-align: center; padding: 30px 20px; color: var(--gray-500);">Aucune notification</li>';
                    }
                })
                .catch(error => {
                    console.error('Erreur:', error);
                    notifList.innerHTML = '<li style="text-align: center; padding: 30px 20px; color: var(--gray-500);">Erreur lors du chargement</li>';
                });
        }

        function markAsRead(id) {
            fetch('{{ path('notifications_mark_read', {'id': '__ID__'}) }}'.replace('__ID__', id), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                showToast('Notification marquée comme lue', 'success');
                fetchNotifications();
            })
            .catch(error => {
                console.error('Erreur:', error);
                showToast('Erreur lors de la mise à jour', 'error');
            });
        }

        // Poll notifications every 30 seconds
        setInterval(() => {
            if (!notifDropdown.classList.contains('hidden')) {
                fetchNotifications();
            }
        }, 30000);

        // ========== MESSAGING WIDGET ==========
        const messagingWidget = document.getElementById('messaging-widget');
        const messagingButton = document.getElementById('messaging-button');
        const messagingBadge = document.getElementById('messaging-badge');
        const messagingView = document.getElementById('messaging-view');
        const chatView = document.getElementById('chat-view');
        const studentSearch = document.getElementById('student-search');
        const searchResults = document.getElementById('search-results');
        const conversationsList = document.getElementById('conversations-list');
        const messagesArea = document.getElementById('messages-area');
        const messageInput = document.getElementById('message-input');
        const sendBtn = document.getElementById('send-message-btn');

        // State management
        const state = {
            currentConversationId: null,
            currentChatName: null,
            lastMessageId: 0,
            previousUnreadCount: 0,
            isLoading: false,
            isSending: false,
            messagePollingInterval: null,
            unreadPollingInterval: null
        };

        // Debounce helper
        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        messagingButton.addEventListener('click', toggleMessaging);
        studentSearch.addEventListener('input', debounce(searchStudents, 300));
        studentSearch.addEventListener('focus', () => {
            if (studentSearch.value.trim()) searchResults.style.display = 'block';
        });
        
        messageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
        
        sendBtn.addEventListener('click', sendMessage);
        
        document.addEventListener('click', function(e) {
            if (!searchResults.contains(e.target) && e.target !== studentSearch) {
                searchResults.style.display = 'none';
            }
        });

        function toggleMessaging() {
            messagingWidget.classList.toggle('active');
            messagingButton.classList.toggle('active');
            if (messagingWidget.classList.contains('active')) {
                loadConversations();
                studentSearch.focus();
                stopUnreadPolling();
            } else {
                stopAllPolling();
                startUnreadPolling();
            }
        }

        function startUnreadPolling() {
            if (state.unreadPollingInterval) return;
            updateUnreadCount(false);
            state.unreadPollingInterval = setInterval(() => updateUnreadCount(true), 10000);
        }

        function stopUnreadPolling() {
            if (state.unreadPollingInterval) {
                clearInterval(state.unreadPollingInterval);
                state.unreadPollingInterval = null;
            }
        }

        function stopAllPolling() {
            if (state.messagePollingInterval) {
                clearInterval(state.messagePollingInterval);
                state.messagePollingInterval = null;
            }
            stopUnreadPolling();
        }

        function updateUnreadCount(showToastOnIncrease = false) {
            fetch('{{ path('messaging_unread_count') }}')
            .then(r => r.json())
            .then(data => {
                const count = data.unreadCount || 0;
                if (count > 0) {
                    messagingBadge.textContent = count;
                    messagingBadge.style.display = 'flex';
                } else {
                    messagingBadge.style.display = 'none';
                }
                
                if (showToastOnIncrease && count > state.previousUnreadCount && state.previousUnreadCount > 0) {
                    showToast(`${count - state.previousUnreadCount} nouveau(x) message(s)`, 'info');
                }
                state.previousUnreadCount = count;
            })
            .catch(e => console.error('Unread count error:', e));
        }

        function searchStudents() {
            const query = studentSearch.value.trim();
            if (query.length < 2) {
                searchResults.style.display = 'none';
                return;
            }
            
            fetch('{{ path('messaging_search') }}', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'query=' + encodeURIComponent(query)
            })
            .then(r => r.json())
            .then(data => {
                searchResults.innerHTML = '';
                if (data.results.length > 0) {
                    data.results.forEach(user => {
                        const item = document.createElement('div');
                        item.className = 'search-result-item';
                        const initials = (user.prenom[0] + user.nom[0]).toUpperCase();
                        item.innerHTML = `
                            <div class="search-result-avatar">${initials}</div>
                            <div class="search-result-info">
                                <div class="search-result-name">${user.fullName}</div>
                                <div class="search-result-email">${user.email}</div>
                            </div>
                        `;
                        item.onclick = () => startConversation(user.id, user.fullName);
                        searchResults.appendChild(item);
                    });
                    searchResults.style.display = 'block';
                } else {
                    searchResults.innerHTML = '<div style="padding: 16px; text-align: center; color: var(--gray-500); font-size: 14px;">Aucun étudiant trouvé</div>';
                    searchResults.style.display = 'block';
                }
            })
            .catch(e => console.error('Search error:', e));
        }

        function startConversation(userId, userName) {
            fetch('{{ path('messaging_start', {'userId': '__ID__'}) }}'.replace('__ID__', userId), {
                method: 'POST'
            })
            .then(r => r.json())
            .then(data => {
                studentSearch.value = '';
                searchResults.style.display = 'none';
                openConversation(data.conversationId, userName);
            })
            .catch(e => {
                console.error('Start conversation error:', e);
                showToast('Erreur lors du démarrage de la conversation', 'error');
            });
        }

        function loadConversations() {
            fetch('{{ path('messaging_conversations') }}')
            .then(r => r.json())
            .then(data => {
                conversationsList.innerHTML = '';
                if (data.conversations.length > 0) {
                    document.getElementById('no-conversations').style.display = 'none';
                    data.conversations.forEach(conv => {
                        const li = document.createElement('li');
                        li.className = `conversation-item ${conv.unreadCount > 0 ? 'unread' : ''}`;
                        const nameParts = conv.otherUser.name.split(' ');
                        const initials = (nameParts[0]?.[0] || '') + (nameParts[1]?.[0] || '');
                        let lastMsgPreview = conv.lastMessage ? conv.lastMessage.content.substring(0, 40) : 'Aucun message';
                        li.innerHTML = `
                            <div class="conversation-avatar">${initials}</div>
                            <div class="conversation-info">
                                <div class="conversation-name">${conv.otherUser.name}</div>
                                <div class="conversation-message">${lastMsgPreview}</div>
                            </div>
                            ${conv.unreadCount > 0 ? `<div class="conversation-badge">${conv.unreadCount}</div>` : ''}
                        `;
                        li.onclick = () => openConversation(conv.id, conv.otherUser.name);
                        conversationsList.appendChild(li);
                    });
                } else {
                    document.getElementById('no-conversations').style.display = 'block';
                }
            })
            .catch(e => console.error('Load conversations error:', e));
        }

        function openConversation(convId, otherUserName = null) {
            state.currentConversationId = convId;
            state.lastMessageId = 0;
            state.isLoading = false;
            messagesArea.innerHTML = '';
            
            messagingView.style.display = 'none';
            chatView.style.display = 'flex';
            state.currentChatName = otherUserName;
            
            if (state.currentChatName) {
                const titleEl = document.getElementById('chat-title');
                if (titleEl) titleEl.textContent = state.currentChatName;
            }
            
            // Load initial messages
            loadInitialMessages();
            
            // Start polling for new messages (every 5 seconds)
            if (state.messagePollingInterval) clearInterval(state.messagePollingInterval);
            state.messagePollingInterval = setInterval(pollNewMessages, 5000);
        }

        function backToConversations() {
            state.currentConversationId = null;
            state.lastMessageId = 0;
            state.isLoading = false;
            messagingView.style.display = 'block';
            chatView.style.display = 'none';
            state.currentChatName = null;
            
            if (state.messagePollingInterval) {
                clearInterval(state.messagePollingInterval);
                state.messagePollingInterval = null;
            }
            
            loadConversations();
        }

        function loadInitialMessages() {
            if (!state.currentConversationId || state.isLoading) return;
            
            state.isLoading = true;
            messagesArea.innerHTML = '<div style="text-align:center;padding:20px;color:#6B7280;">Chargement...</div>';
            
            fetch('{{ path('messaging_get_messages', {'id': '__ID__'}) }}'.replace('__ID__', state.currentConversationId))
            .then(r => r.json())
            .then(data => {
                messagesArea.innerHTML = '';
                data.messages.forEach(msg => {
                    renderMessage(msg);
                    if (msg.id > state.lastMessageId) {
                        state.lastMessageId = msg.id;
                    }
                });
                messagesArea.scrollTop = messagesArea.scrollHeight;
                state.isLoading = false;
            })
            .catch(e => {
                console.error('Load messages error:', e);
                messagesArea.innerHTML = '<div style="text-align:center;padding:20px;color:#EF4444;">Erreur de chargement</div>';
                state.isLoading = false;
            });
        }

        function pollNewMessages() {
            if (!state.currentConversationId || state.isLoading) return;
            
            fetch(`{{ path('messaging_check_new', {'id': '__ID__'}) }}`.replace('__ID__', state.currentConversationId) + 
                  `?lastMessageId=${state.lastMessageId}`)
            .then(r => r.json())
            .then(data => {
                if (data.hasNew && data.messages.length > 0) {
                    const wasAtBottom = messagesArea.scrollHeight - messagesArea.scrollTop <= messagesArea.clientHeight + 100;
                    
                    data.messages.forEach(msg => {
                        renderMessage(msg);
                        if (msg.id > state.lastMessageId) {
                            state.lastMessageId = msg.id;
                        }
                    });
                    
                    if (wasAtBottom) {
                        messagesArea.scrollTop = messagesArea.scrollHeight;
                    }
                    
                    updateUnreadCount(false);
                    loadConversations();
                }
            })
            .catch(e => console.error('Poll new messages error:', e));
        }

        function renderMessage(msg) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${msg.sender.id === {{ app.user.id }} ? 'own' : 'other'}`;
            msgDiv.dataset.messageId = msg.id;
            
            const timeStr = new Date(msg.createdAt).toLocaleTimeString('fr-FR', {hour: '2-digit', minute: '2-digit'});
            const statusParts = [];
            if (msg.isEdited) statusParts.push('Modifie');
            if (msg.sender.id === {{ app.user.id }}) {
                statusParts.push(msg.isRead ? 'Vu' : 'Envoye');
            }
            const statusText = statusParts.join(' • ');
            
            msgDiv.innerHTML = `
                <div class="message-bubble">${escapeHtml(msg.content)}</div>
                <div class="message-meta">
                    <span class="message-time">${timeStr}</span>
                    ${statusText ? `<span class=\"message-status\">${statusText}</span>` : ''}
                    ${msg.sender.id === {{ app.user.id }} ? `
                        <div class=\"message-actions\">
                            <button class=\"message-action-btn\" data-action=\"edit\" data-id=\"${msg.id}\">Modifier</button>
                            <button class=\"message-action-btn\" data-action=\"delete\" data-id=\"${msg.id}\">Supprimer</button>
                        </div>
                    ` : ''}
                </div>
            `;
            
            messagesArea.appendChild(msgDiv);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        messagesArea.addEventListener('click', function(e) {
            const target = e.target;
            if (!target || !target.dataset) return;

            const action = target.dataset.action;
            const messageId = target.dataset.id;
            if (!action || !messageId) return;

           if (action === 'edit') {
                const messageDiv = target.closest('.message');
                const currentContent = messageDiv.querySelector('.message-bubble').textContent;
                const newContent = prompt('Modifier le message:', currentContent);
                
                if (!newContent || !newContent.trim() || newContent.trim() === currentContent) return;
                
                // Optimistic update
                const bubble = messageDiv.querySelector('.message-bubble');
                const oldContent = bubble.textContent;
                bubble.textContent = newContent.trim();
                target.disabled = true;
                
                fetch('{{ path('messaging_edit_message', {'id': '__ID__'}) }}'.replace('__ID__', messageId), {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                    body: 'content=' + encodeURIComponent(newContent.trim())
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        // Update status to show "Modifie"
                        const statusEl = messageDiv.querySelector('.message-status');
                        if (statusEl && !statusEl.textContent.includes('Modifie')) {
                            statusEl.textContent = 'Modifie • ' + statusEl.textContent;
                        }
                        showToast('Message modifie', 'success');
                    } else {
                        bubble.textContent = oldContent;
                        showToast('Erreur lors de la modification', 'error');
                    }
                    target.disabled = false;
                })
                .catch(e => {
                    console.error('Edit message error:', e);
                    bubble.textContent = oldContent;
                    showToast('Erreur de connexion', 'error');
                    target.disabled = false;
                });
            }

            if (action === 'delete') {
                if (!confirm('Supprimer ce message ?')) return;
                
                const messageDiv = target.closest('.message');
                messageDiv.style.opacity = '0.5';
                target.disabled = true;
                
                fetch('{{ path('messaging_delete_message', {'id': '__ID__'}) }}'.replace('__ID__', messageId), {
                    method: 'POST'
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        messageDiv.remove();
                        showToast('Message supprime', 'success');
                        loadConversations();
                    } else {
                        messageDiv.style.opacity = '1';
                        target.disabled = false;
                        showToast('Erreur lors de la suppression', 'error');
                    }
                })
                .catch(e => {
                    console.error('Delete message error:', e);
                    messageDiv.style.opacity = '1';
                    target.disabled = false;
                    showToast('Erreur de connexion', 'error');
                });
            }
        });

        function sendMessage() {
            const content = messageInput.value.trim();
            if (!content || !state.currentConversationId || state.isSending) return;
            
            state.isSending = true;
            sendBtn.disabled = true;
            messageInput.value = '';
            
            // Optimistic UI - show message immediately
            const tempMsg = {
                id: 'temp-' + Date.now(),
                content: content,
                sender: { id: {{ app.user.id }}, name: 'Vous' },
                createdAt: new Date().toISOString(),
                isRead: false,
                isEdited: false
            };
            renderMessage(tempMsg);
            messagesArea.scrollTop = messagesArea.scrollHeight;
            
            fetch('{{ path('messaging_send', {'id': '__ID__'}) }}'.replace('__ID__', state.currentConversationId), {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'content=' + encodeURIComponent(content)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    // Remove temp message and replace with real one
                    const tempMsgDiv = messagesArea.querySelector(`[data-message-id="${tempMsg.id}"]`);
                    if (tempMsgDiv) tempMsgDiv.remove();
                    
                    // Update last message ID
                    if (data.message.id > state.lastMessageId) {
                        state.lastMessageId = data.message.id;
                    }
                    
                    renderMessage(data.message);
                    messagesArea.scrollTop = messagesArea.scrollHeight;
                    loadConversations();
                } else {
                    // Remove temp message on error
                    const tempMsgDiv = messagesArea.querySelector(`[data-message-id="${tempMsg.id}"]`);
                    if (tempMsgDiv) tempMsgDiv.remove();
                    messageInput.value = content;
                    showToast('Erreur lors de l\'envoi du message', 'error');
                }
                state.isSending = false;
                sendBtn.disabled = false;
            })
            .catch(e => {
                console.error('Send message error:', e);
                // Remove temp message on error
                const tempMsgDiv = messagesArea.querySelector(`[data-message-id="${tempMsg.id}"]`);
                if (tempMsgDiv) tempMsgDiv.remove();
                messageInput.value = content;
                showToast('Erreur de connexion', 'error');
                state.isSending = false;
                sendBtn.disabled = false;
            });
        }

        // Start unread count polling when page loads
        startUnreadPolling();

        function toggleTask(taskId) {
            fetch(`/tasks/${taskId}/toggle`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                console.log('Tâche mise à jour:', data);
                location.reload();
            })
            .catch(error => console.error('Erreur:', error));
        }

        // Highlight active section based on current page
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('.nav a');
            
            navLinks.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });

        // ========== AI EDUCATION CHATBOT ==========
        const aiChatButton = document.getElementById('ai-chat-button');
        const aiChatWidget = document.getElementById('ai-chat-widget');
        const aiMessagesArea = document.getElementById('ai-messages-area');
        const aiMessageInput = document.getElementById('ai-message-input');
        const aiSendBtn = document.getElementById('ai-send-btn');

        const aiState = {
            isSending: false,
            conversationHistory: []
        };

        aiChatButton.addEventListener('click', toggleAIChat);
        aiMessageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendAIMessage();
            }
        });
        aiSendBtn.addEventListener('click', sendAIMessage);

        function toggleAIChat() {
            aiChatWidget.classList.toggle('active');
            aiChatButton.classList.toggle('active');
            if (aiChatWidget.classList.contains('active')) {
                aiMessageInput.focus();
                if (aiMessagesArea.children.length === 0) {
                    addAIMessage('Bonjour! 👋 Je suis votre assistant IA éducatif. Je peux répondre à vos questions sur les différents sujets académiques. N\'hésitez pas à me poser vos questions!', 'ai');
                }
            }
        }

        function addAIMessage(content, sender = 'ai') {
            const msgDiv = document.createElement('div');
            msgDiv.className = `ai-message ${sender}`;
            
            const bubble = document.createElement('div');
            bubble.className = 'ai-message-bubble';
            bubble.textContent = content;
            msgDiv.appendChild(bubble);
            
            aiMessagesArea.appendChild(msgDiv);
            aiMessagesArea.scrollTop = aiMessagesArea.scrollHeight;
            
            aiState.conversationHistory.push({
                sender: sender,
                content: content,
                timestamp: new Date().toISOString()
            });
        }

        function addAITypingIndicator() {
            const typingDiv = document.createElement('div');
            typingDiv.className = 'ai-typing-indicator';
            typingDiv.id = 'ai-typing-indicator';
            
            for (let i = 0; i < 3; i++) {
                const dot = document.createElement('div');
                dot.className = 'ai-typing-dot';
                typingDiv.appendChild(dot);
            }
            
            aiMessagesArea.appendChild(typingDiv);
            aiMessagesArea.scrollTop = aiMessagesArea.scrollHeight;
        }

        function removeAITypingIndicator() {
            const indicator = document.getElementById('ai-typing-indicator');
            if (indicator) {
                indicator.remove();
            }
        }

        function sendAIMessage() {
            const content = aiMessageInput.value.trim();
            if (!content || aiState.isSending) return;
            
            aiState.isSending = true;
            aiSendBtn.disabled = true;
            aiMessageInput.value = '';
            
            // Show user message
            addAIMessage(content, 'user');
            
            // Show typing indicator
            addAITypingIndicator();
            
            // Send to server
            fetch('{{ path('chatbot_send') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    message: content
                })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                removeAITypingIndicator();
                
                if (data.success) {
                    const aiResponse = data.response || data.message;
                    addAIMessage(aiResponse, 'ai');
                    showToast('✅ Réponse reçue', 'success');
                } else {
                    const errorMsg = data.message || 'Impossible de recevoir une réponse';
                    addAIMessage('⚠️ ' + errorMsg, 'ai');
                    showToast('❌ Erreur: ' + errorMsg, 'error');
                }
                
                aiState.isSending = false;
                aiSendBtn.disabled = false;
                aiMessageInput.focus();
            })
            .catch(error => {
                console.error('AI Chat error:', error);
                removeAITypingIndicator();
                addAIMessage('⚠️ Erreur de connexion. Assurez-vous que l\'API Ollama est en cours d\'exécution.', 'ai');
                showToast('❌ Erreur de connexion', 'error');
                aiState.isSending = false;
                aiSendBtn.disabled = false;
                aiMessageInput.focus();
            });
        }
    </script>
</body>
</html>