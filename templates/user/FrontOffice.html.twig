        </aside>

        <!-- Main Content -->
        <main class="main">
        <header class="header">
            <div class="header-content">
                <h1>Mes Tâches</h1>
                <p>Gérez et suivez toutes vos tâches académiques</p>
            </div>
            <div style="display: flex; gap: 1rem;">
                <button id="weatherBtn" class="btn btn-insights">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 2v4M12 22v-4M4 12H2M22 12h-2M19.07 4.93l-2.83 2.83M6.9 17.1l-2.82 2.82M17.1 6.9l2.82-2.82M4.93 19.07l2.83-2.83"/>
                        <path d="M12 6a6 6 0 0 0-6 6 6 6 0 0 0 12 0 6 6 0 0 0-6-6z"/>
                        <path d="M12 10v4M10 12h4"/>
                    </svg>
                    Conseil Météo IA
                </button>
                <a href="{{ path('app_task_add') }}" class="btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                    Nouvelle Tâche
                </a>
            </div>
        </header>


            {% set totalTasks = stats.counts.total %}
            {% set completedTasks = stats.counts.completed %}
            {% set abandonedTasks = stats.counts.abandoned %}
            {% set inProgressTasks = stats.counts.inProgress %}
            {% set pausedTasks = stats.counts.paused %}
            {% set overdueTasks = stats.counts.overdue %}
            {% set highPriorityTasks = stats.counts.highPriority %}
            <div class="task-stats">
                <div class="stat-card">
                    <div class="stat-value">{{ totalTasks }}</div>
                    <div class="stat-label">📋 Total des tâches</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ inProgressTasks + pausedTasks + overdueTasks }}</div>
                    <div class="stat-label">⏳ En cours</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ completedTasks }}</div>
                    <div class="stat-label">✅ Terminées</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{{ highPriorityTasks }}</div>
                    <div class="stat-label">🔥 Haute priorité</div>
                </div>
            </div>

            {# Charts section #}
            <div class="charts-section">
                <h2>Analyses visuelles</h2>
                <div class="charts-grid" style="grid-template-columns: repeat(2, 1fr);">
                    {# Status Chart - Manual #}
                    <div class="chart-card">
                        <h3>📊 Répartition des tâches par statut</h3>
                        <canvas id="statusChart" width="400" height="300"></canvas>
                    </div>
                    
                    {# Priority Chart - Manual #}
                    <div class="chart-card">
                        <h3>🎯 Répartition par priorité</h3>
                        <canvas id="priorityChart" width="400" height="300"></canvas>
                    </div>
                    
                    {# Progress Chart - Manual - spans full width #}
                    <div class="chart-card" style="grid-column: span 2;">
                        <h3>📈 Progression sur 30 jours</h3>
                        <canvas id="progressChart" width="800" height="300"></canvas>
                    </div>
                </div>
            </div>

            <div class="tasks-container">
                <div class="tasks-header">
                    <h2 class="tasks-title">Toutes les tâches ({{ totalTasks }})</h2>
                    <a href="#" id="btnInsights" class="btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12v-2a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v2"/>
                            <path d="M3 12h4l2 3 3-6 2 3 3-3 2 3 2-3"/>
                            <path d="M3 12v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4"/>
                        </svg>
                        Analyse & Insights
                    </a>
                </div>

                <div class="task-grid">
                    {# Tâches actives #}
                    {% if activeTasks is defined and activeTasks|length > 0 %}
                        <h2 class="section-title">Tâches en cours ({{ activeTasks|length }})</h2>
                        {% for task in activeTasks %}
                            {% set priorityClass = task.priorite == 'ELEVEE' ? 'high' : (task.priorite == 'FAIBLE' ? 'low' : 'medium') %}
                            {% set statusSlug = task.statut|lower|replace({'_': ''}) %}
                            
                            <div class="task-card {{ priorityClass }}-priority">
                                <div class="task-header">
                                    <h3 class="task-title">{{ task.titre|default('Sans titre') }}</h3>
                                    <span class="task-status status-{{ task.statut|lower|replace({'_': '-'}) }}">
                                        {{ task.statut|replace({'_': ' '})|title }}
                                    </span>
                                </div>
                                
                                <div class="task-content">
                                    {% if task.description %}
                                        <div class="task-description">{{ task.description|slice(0, 100) }}{% if task.description|length > 100 %}...{% endif %}</div>
                                    {% endif %}
                                    
                                    <div class="task-details">
                                        <div class="detail-item">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M12 8v4l3 3"/>
                                                <circle cx="12" cy="12" r="10"/>
                                            </svg>
                                            <span>Priorité: 
                                                <strong>{{ task.priorite|default('MOYENNE')|title }}</strong>
                                                <span class="priority-badge priority-{{ task.priorite|default('MOYEN')|lower }}">{{ task.priorite|default('MOYEN') }}</span>
                                            </span>
                                        </div>
                                        
                                        {% if task.dateEcheance %}
                                            <div class="detail-item">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                                    <line x1="16" y1="2" x2="16" y2="6"/>
                                                    <line x1="8" y1="2" x2="8" y2="6"/>
                                                    <line x1="3" y1="10" x2="21" y2="10"/>
                                                </svg>
                                                <span>Échéance: <strong>{{ task.dateEcheance|date('d/m/Y') }}</strong></span>
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="task-prediction">
                                        {% if task.prediction is not null %}
                                            {% set probability = task.prediction * 100 %}
                                            {% set probabilityColor = probability >= 70 ? 'high' : (probability >= 40 ? 'medium' : 'low') %}
                                            
                                            <div class="probability-container">
                                                <div class="probability-header">
                                                    <span class="probability-label">
                                                        <svg class="probability-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <circle cx="12" cy="12" r="10"/>
                                                            <path d="M12 6v6l4 2"/>
                                                        </svg>
                                                        Probabilité de complétion
                                                    </span>
                                                    <span class="probability-value {{ probabilityColor }}">
                                                        {{ probability|number_format(1, '.', ',') }}%
                                                    </span>
                                                </div>
                                                
                                                <div class="progress-bar-container">
                                                    <div class="progress-bar-bg">
                                                        <div class="progress-bar-fill {{ probabilityColor }}" 
                                                            style="width: {{ probability }}%"></div>
                                                    </div>
                                                    
                                                    <div class="progress-markers">
                                                        <span class="marker low">0%</span>
                                                        <span class="marker medium">50%</span>
                                                        <span class="marker high">100%</span>
                                                    </div>
                                                </div>
                                                
                                                <div class="probability-status {{ probabilityColor }}">
                                                    {% if probability >= 70 %}
                                                        <span class="status-indicator">✓</span> Bonnes chances de réussite
                                                    {% elseif probability >= 40 %}
                                                        <span class="status-indicator">⚠️</span> Risque modéré - Restez concentré
                                                    {% else %}
                                                        <span class="status-indicator">!</span> Nécessite votre attention immédiate
                                                    {% endif %}
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="probability-container no-data">
                                                <div class="probability-header">
                                                    <span class="probability-label">
                                                        <svg class="probability-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <circle cx="12" cy="12" r="10"/>
                                                            <line x1="12" y1="8" x2="12" y2="12"/>
                                                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                                                        </svg>
                                                        Probabilité de complétion
                                                    </span>
                                                </div>
                                                <div class="no-data-message">
                                                    <span class="no-data-icon">📊</span>
                                                    Analyse en attente de données
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                    
                                    <div class="task-tags">
                                        <span class="task-tag tag-{{ task.type|default('personnel')|lower }}">
                                            {{ task.type|default('Personnel')|upper }}
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="task-footer">
                                    <div class="task-actions">
                                        <a href="{{ path('app_task_show', {'id': task.id}) }}" class="action-btn primary">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10"/>
                                                <path d="M12 16v-4"/>
                                                <circle cx="12" cy="8" r="0.5" fill="currentColor" stroke="none"/>
                                            </svg>
                                            Détails
                                        </a>
                                        <a href="{{ path('app_task_edit', {'id': task.id}) }}" class="action-btn">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                            Modifier
                                        </a>
                                    </div>
                                    <span class="task-date">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        {{ (task.updatedAt ?? task.createdAt)|date('d/m/Y') }}
                                    </span>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}

                    {# Tâches archivées #}
                    {% if archivedTasks is defined and archivedTasks|length > 0 %}
                        <h2 class="section-title archived-title">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 8v13H3V8M1 3h22v5H1zM10 12h4"/>
                            </svg>
                            Tâches archivées ({{ archivedTasks|length }})
                        </h2>
                        
                        {% for task in archivedTasks %}
                            {% set priorityClass = task.priorite == 'ELEVEE' ? 'high' : (task.priorite == 'FAIBLE' ? 'low' : 'medium') %}
                            
                            <div class="task-card archived {{ priorityClass }}-priority">
                                <div class="task-header">
                                    <h3 class="task-title">{{ task.titre|default('Sans titre') }}</h3>
                                    <span class="task-status status-{{ task.statut|lower|replace({'_': '-'}) }}">
                                        {% if task.statut == 'TERMINE' %}✅{% elseif task.statut == 'ABANDON' %}❌{% elseif task.statut == 'EN_RETARD' %}⚠️{% else %}📦{% endif %}
                                        {{ task.statut|replace({'_': ' '})|title }}
                                    </span>
                                </div>
                                
                                <div class="task-content">
                                    {% if task.description %}
                                        <div class="task-description">{{ task.description|slice(0, 100) }}{% if task.description|length > 100 %}...{% endif %}</div>
                                    {% endif %}
                                    
                                    <div class="task-details">
                                        <div class="detail-item">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M12 8v4l3 3"/>
                                                <circle cx="12" cy="12" r="10"/>
                                            </svg>
                                            <span>Priorité: <strong>{{ task.priorite|default('MOYENNE')|title }}</strong></span>
                                            <span class="archived-badge">ARCHIVÉE</span>
                                        </div>
                                        
                                        {% if task.dateEcheance %}
                                            <div class="detail-item">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                                    <line x1="16" y1="2" x2="16" y2="6"/>
                                                    <line x1="8" y1="2" x2="8" y2="6"/>
                                                    <line x1="3" y1="10" x2="21" y2="10"/>
                                                </svg>
                                                <span>Échéance: <strong>{{ task.dateEcheance|date('d/m/Y') }}</strong></span>
                                            </div>
                                        {% endif %}
                                        
                                        <div class="detail-item">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10"/>
                                                <path d="M12 16v-4"/>
                                                <circle cx="12" cy="8" r="0.5" fill="currentColor" stroke="none"/>
                                            </svg>
                                            <span>Statut final: 
                                                <strong style="color: {% if task.statut == 'TERMINE' %}#059669{% elseif task.statut == 'ABANDON' %}#b91c1c{% elseif task.statut == 'EN_RETARD' %}#d97706{% else %}#6b7280{% endif %};">
                                                    {{ task.statut|replace({'_': ' '})|title }}
                                                </strong>
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <div class="task-tags">
                                        <span class="task-tag tag-{{ task.type|default('personnel')|lower }}">
                                            {{ task.type|default('Personnel')|upper }}
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="task-footer">
                                    <div class="task-actions">
                                        <a href="{{ path('app_task_show', {'id': task.id}) }}" class="action-btn primary" style="background: #6b7280; border-color: #6b7280;">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10"/>
                                                <path d="M12 16v-4"/>
                                                <circle cx="12" cy="8" r="0.5" fill="currentColor" stroke="none"/>
                                            </svg>
                                            Voir détails
                                        </a>
                                    </div>
                                    <span class="task-date">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        {{ (task.updatedAt ?? task.createdAt)|date('d/m/Y') }}
                                    </span>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}

                    {# État vide #}
                    {% if (activeTasks|default([])|length == 0) and (archivedTasks|default([])|length == 0) %}
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 11l3 3 8-8"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                            </svg>
                            <h3>Aucune tâche pour le moment</h3>
                            <p>Créez votre première tâche pour commencer à organiser votre travail</p>
                            <a href="{{ path('app_task_add') }}" class="btn" style="margin-top: 1rem;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 5v14M5 12h14"/>
                                </svg>
                                Créer une tâche
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <footer class="footer">
                <p>ESPRIT Assistant Étudiant • © {{ "now"|date("Y") }} • Tous droits réservés</p>
            </footer>
        </main>
    </div>

    <!-- Modal Insights -->
    <div id="insightsModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12v-2a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v2"/>
                        <path d="M3 12h4l2 3 3-6 2 3 3-3 2 3 2-3"/>
                        <path d="M3 12v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4"/>
                    </svg>
                    Analyse & Insights
                </h2>
                <button id="closeInsights">✕</button>
            </div>
            <div class="modal-body" id="insightsContainer">
                <!-- Contenu dynamique -->
            </div>
        </div>
    </div>

    <!-- Blur overlay (hidden by default) -->
    <div id="blur-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; backdrop-filter: blur(3px); background: rgba(255, 255, 255, 0.1); z-index: 9998; display: none;"></div>

    <!-- Floating notification dropdown (placed outside sidebar) -->
    <div id="notif-dropdown" class="dropdown hidden">
        <ul id="notif-list"></ul>
    </div>

    <div id="toast-message" style="position: fixed; bottom: 20px; right: 20px; background: #333; color: white; padding: 10px 20px; border-radius: 8px; opacity: 0; transition: opacity 0.3s; z-index: 10000;"></div>

        <!-- Load dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <!-- Weather Modal -->
    <div id="weatherModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); z-index: 10001; justify-content: center; align-items: center;">
        <div class="modal-content" style="max-width: 700px">
            <div class="modal-header" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                <h2>
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 2v4M12 22v-4M4 12H2M22 12h-2M19.07 4.93l-2.83 2.83M6.9 17.1l-2.82 2.82M17.1 6.9l2.82-2.82M4.93 19.07l2.83-2.83"/>
                        <path d="M12 6a6 6 0 0 0-6 6 6 6 0 0 0 12 0 6 6 0 0 0-6-6z"/>
                    </svg>
                    Conseil Météo IA
                </h2>
                <button id="closeWeatherModal" style="position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(255,255,255,0.2); border: none; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: white; font-size: 1.2rem; transition: all 0.2s;">✕</button>
            </div>
            <div class="modal-body" id="weatherResult" style="min-height: 200px;">
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem;">
                    <div style="width: 48px; height: 48px; border: 3px solid #f3f4f6; border-top-color: #3b82f6; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 1rem;"></div>
                    <p style="color: var(--gray-600);">Chargement des données météo...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
            // Toast helper
            function showToast(message, type = 'info') {
                const toast = document.getElementById('toast-message');
                toast.textContent = message;
                toast.style.opacity = '1';
                toast.style.background = type === 'success' ? '#10b981' : (type === 'error' ? '#ef4444' : '#333');
                setTimeout(() => {
                    toast.style.opacity = '0';
                }, 3000);
            }

            // Notification functions
            document.addEventListener('DOMContentLoaded', function() {
                // Icon click handler
                document.getElementById('notif-icon')?.addEventListener('click', function(e) {
                    e.preventDefault();
                    const dropdown = document.getElementById('notif-dropdown');
                    const overlay = document.getElementById('blur-overlay');
                    
                    dropdown.classList.toggle('hidden');
                    overlay.style.display = dropdown.classList.contains('hidden') ? 'none' : 'block';
                    
                    if (!dropdown.classList.contains('hidden')) {
                        fetchNotifications();
                        positionDropdown(dropdown, this);
                    }
                });

                // Close dropdown on outside click
                document.addEventListener('click', function(e) {
                    const dropdown = document.getElementById('notif-dropdown');
                    const icon = document.getElementById('notif-icon');
                    const overlay = document.getElementById('blur-overlay');
                    
                    if (dropdown && icon && !dropdown.contains(e.target) && !icon.contains(e.target)) {
                        dropdown.classList.add('hidden');
                        overlay.style.display = 'none';
                        dropdown.style.top = '';
                        dropdown.style.left = '';
                    }
                });

                // Initialize charts
                initializeCharts();
                
                // Initialize weather modal
                initWeatherModal();
            });

            function positionDropdown(dropdown, icon) {
                const iconRect = icon.getBoundingClientRect();
                const dropdownWidth = dropdown.offsetWidth;

                let left = iconRect.right - dropdownWidth;
                let top = iconRect.bottom + 5;

                if (left < 10) left = 10;
                if (left + dropdownWidth > window.innerWidth - 10) {
                    left = window.innerWidth - dropdownWidth - 10;
                }
                if (top + dropdown.offsetHeight > window.innerHeight - 10) {
                    top = iconRect.top - dropdown.offsetHeight - 5;
                }
                if (top < 10) top = 10;

                dropdown.style.top = top + 'px';
                dropdown.style.left = left + 'px';
            }

            function fetchNotifications() {
                fetch('{{ path("notifications_fetch") }}')
                    .then(res => res.json())
                    .then(data => {
                        const list = document.getElementById('notif-list');
                        list.innerHTML = '';
                        let unreadCount = 0;

                        if (data.length === 0) {
                            list.innerHTML = '<li style="text-align: center; padding: 2rem; color: #6b7280; font-style: italic; cursor: default;">Aucune notification</li>';
                            document.getElementById('notif-count').textContent = '0';
                            return;
                        }

                        data.forEach(n => {
                            if (!n.isRead) unreadCount++;

                            const li = document.createElement('li');
                            // Set background color based on read status
                            li.style.padding = '1rem';
                            li.style.borderBottom = '1px solid #e5e7eb';
                            li.style.cursor = 'pointer';
                            li.style.transition = 'background-color 0.2s';
                            
                            // Unread = light red, Read = white
                            li.style.backgroundColor = n.isRead ? '#ffffff' : '#fee2e2';
                            
                            // Add hover effect
                            li.addEventListener('mouseenter', function() {
                                this.style.backgroundColor = n.isRead ? '#f9fafb' : '#fecaca';
                            });
                            
                            li.addEventListener('mouseleave', function() {
                                this.style.backgroundColor = n.isRead ? '#ffffff' : '#fee2e2';
                            });
                            
                            li.dataset.id = n.id;

                            // Build notification content - REMOVED REPORTER BUTTON
                            let buttonsHtml = '';
                            if (n.type === 'WARNING' && n.taskId) {
                                buttonsHtml = `
                                    <form method="post" action="/tache/${n.taskId}/action-user" 
                                        style="display:flex; gap:5px; margin-top:8px;"
                                        onClick="event.stopPropagation();">

                                        <button type="submit" name="action" value="TERMINE"
                                            class="notif-action-btn finish">
                                            ✔ Terminer
                                        </button>

                                        <button type="submit" name="action" value="ABANDON"
                                            class="notif-action-btn abandon"
                                            onclick="return confirm('Êtes-vous sûr de vouloir abandonner cette tâche ?');">
                                            ✖ Abandonner
                                        </button>

                                    </form>
                                `;
                            }

                            li.innerHTML = `
                                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                                    <div style="font-weight: ${n.isRead ? '400' : '600'};">${n.message}</div>
                                    <div style="font-size: 0.7rem; color: #6b7280; display: flex; align-items: center; gap: 0.5rem;">
                                        <span>🕐 ${n.createdAt}</span>
                                        ${!n.isRead ? '<span style="background: #dc2626; color: white; padding: 0.1rem 0.4rem; border-radius: 12px; font-size: 0.6rem;">Nouveau</span>' : ''}
                                    </div>
                                    ${buttonsHtml}
                                </div>
                            `;

                            // Mark as read when clicking on the notification (but not on buttons)
                            li.addEventListener('click', function(e) {
                                if (e.target.tagName === 'BUTTON') return;
                                e.stopPropagation();
                                if (!n.isRead) {
                                    markAsRead(n.id, this);
                                }
                            });

                            list.appendChild(li);
                        });

                        document.getElementById('notif-count').textContent = unreadCount;
                    })
                    .catch(() => {
                        document.getElementById('notif-list').innerHTML = '<li style="color: #dc2626; padding: 1rem; text-align: center;">Erreur de chargement</li>';
                    });
            }

            function markAsRead(id, element = null) {
                fetch('{{ path("notifications_mark_read", {"id": "ID_PLACEHOLDER"}) }}'.replace('ID_PLACEHOLDER', id), {
                    method: 'POST',
                    headers: { 
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/json'
                    }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const count = parseInt(document.getElementById('notif-count').textContent);
                        document.getElementById('notif-count').textContent = Math.max(0, count - 1);
                        
                        // If element is provided, update it visually
                        if (element) {
                            // Change background to white
                            element.style.backgroundColor = '#ffffff';
                            
                            // Update font weight
                            const titleDiv = element.querySelector('div > div:first-child');
                            if (titleDiv) titleDiv.style.fontWeight = '400';
                            
                            // Remove the "Nouveau" badge
                            const badge = element.querySelector('span[style*="background: #dc2626"]');
                            if (badge) badge.remove();
                            
                            // Update hover effect
                            element.addEventListener('mouseenter', function() {
                                this.style.backgroundColor = '#f9fafb';
                            });
                            
                            element.addEventListener('mouseleave', function() {
                                this.style.backgroundColor = '#ffffff';
                            });
                        }
                    }
                })
                .catch(console.error);
            }

            function finishTask(taskId, notifId) {
                performTaskAction('{{ path("task_finish", {"id": "ID_PLACEHOLDER"}) }}'.replace('ID_PLACEHOLDER', taskId), 'Tâche terminée avec succès !', notifId);
            }

            function abandonTask(taskId, notifId) {
                performTaskAction('{{ path("task_abandon", {"id": "ID_PLACEHOLDER"}) }}'.replace('ID_PLACEHOLDER', taskId), 'Tâche abandonnée.', notifId);
            }

            function performTaskAction(url, successMessage, notifId) {
                // Add timestamp to ensure updatedAt will be updated
                const data = {
                    timestamp: new Date().toISOString(),
                    action: successMessage.includes('terminée') ? 'complete' : 'abandon'
                };
                
                fetch(url, { 
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(data)
                })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showToast(successMessage, 'success');
                            
                            // Mark the notification as read and update UI
                            const notificationElement = document.querySelector(`li[data-id="${notifId}"]`);
                            if (notificationElement) {
                                // Change background to white
                                notificationElement.style.backgroundColor = '#ffffff';
                                
                                // Remove buttons
                                const buttonsDiv = notificationElement.querySelector('div > div:last-child');
                                if (buttonsDiv && buttonsDiv.tagName === 'DIV' && buttonsDiv.children.length > 0 && buttonsDiv.children[0].classList.contains('notif-action-btn')) {
                                    buttonsDiv.remove();
                                }
                                
                                // Update title font weight
                                const titleDiv = notificationElement.querySelector('div > div:first-child');
                                if (titleDiv) titleDiv.style.fontWeight = '400';
                                
                                // Remove badge
                                const badge = notificationElement.querySelector('span[style*="background: #dc2626"]');
                                if (badge) badge.remove();
                                
                                // Update hover effect
                                notificationElement.addEventListener('mouseenter', function() {
                                    this.style.backgroundColor = '#f9fafb';
                                });
                                
                                notificationElement.addEventListener('mouseleave', function() {
                                    this.style.backgroundColor = '#ffffff';
                                });
                            }
                            
                            // Update the unread count
                            const count = parseInt(document.getElementById('notif-count').textContent);
                            document.getElementById('notif-count').textContent = Math.max(0, count - 1);
                            
                        } else {
                            showToast('Erreur lors de l\'action', 'error');
                        }
                    })
                    .catch(() => showToast('Erreur réseau', 'error'));
            }

            // Poll every 30 seconds
            setInterval(() => {
                const dropdown = document.getElementById('notif-dropdown');
                if (dropdown && !dropdown.classList.contains('hidden')) {
                    fetchNotifications();
                }
            }, 30000);

            // Chart initialization
            function initializeCharts() {
                // Get stats from the page
                const totalTasks = parseInt(document.querySelector('.stat-card:first-child .stat-value')?.textContent || '0');
                const inProgress = parseInt(document.querySelector('.stat-card:nth-child(2) .stat-value')?.textContent || '0');
                const completed = parseInt(document.querySelector('.stat-card:nth-child(3) .stat-value')?.textContent || '0');
                const highPriority = parseInt(document.querySelector('.stat-card:nth-child(4) .stat-value')?.textContent || '0');
                
                // Calculate other values
                const pending = Math.max(0, totalTasks - inProgress - completed);
                const mediumPriority = Math.floor(totalTasks * 0.3); // Example calculation
                const lowPriority = Math.max(0, totalTasks - highPriority - mediumPriority);

                // Status Chart
                const statusCtx = document.getElementById('statusChart')?.getContext('2d');
                if (statusCtx) {
                    // Get all the status counts
                    const inProgress = {{ stats.counts.inProgress|default(0) }};
                    const completed = {{ stats.counts.completed|default(0) }};
                    const abandoned = {{ stats.counts.abandoned|default(0) }};
                    const overdue = {{ stats.counts.overdue|default(0) }};
                    const paused = {{ stats.counts.paused|default(0) }};
                    const totalTasks = {{ stats.counts.total|default(0) }};
                    
                    // Calculate "À faire" (total minus all other statuses)
                    const todo = Math.max(0, totalTasks - inProgress - completed - abandoned - overdue - paused);
                    
                    new Chart(statusCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['À faire', 'En cours', 'Terminées', 'Abandonnées', 'En retard', 'En pause'],
                            datasets: [{
                                data: [todo, inProgress, completed, abandoned, overdue, paused],
                                backgroundColor: [
                                    '#f59e0b',  // À faire - orange
                                    '#3b82f6',  // En cours - blue
                                    '#10b981',  // Terminées - green
                                    '#ef4444',  // Abandonnées - RED
                                    '#d97706',  // En retard - dark orange
                                    '#6b7280'   // En pause - gray
                                ],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: {
                                        boxWidth: 12,
                                        padding: 15
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            const label = context.label || '';
                                            const value = context.raw || 0;
                                            const percentage = totalTasks > 0 ? ((value / totalTasks) * 100).toFixed(1) : 0;
                                            return label + ': ' + value + ' tâche' + (value > 1 ? 's' : '') + ' (' + percentage + '%)';
                                        }
                                    }
                                }
                            },
                            cutout: '60%'
                        }
                    });
                }

                // Priority Chart
                const priorityCtx = document.getElementById('priorityChart')?.getContext('2d');
                if (priorityCtx) {
                    new Chart(priorityCtx, {
                        type: 'bar',
                        data: {
                            labels: ['Haute', 'Moyenne', 'Basse'],
                            datasets: [{
                                label: 'Nombre de tâches',
                                data: [highPriority, mediumPriority, lowPriority],
                                backgroundColor: [
                                    '#ef4444',  // red
                                    '#f59e0b',  // orange
                                    '#10b981'   // green
                                ],
                                borderRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: {
                                    display: false
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: {
                                        display: true,
                                        color: '#e5e7eb'
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
                }

                // NEW: Progress Chart
                const progressCtx = document.getElementById('progressChart')?.getContext('2d');
                if (progressCtx) {
                    // Get progress data from Twig
                    const progressLabels = {{ progressLabels|json_encode|raw }};
                    const progressCreated = {{ progressCreated|json_encode|raw }};
                    const progressCompleted = {{ progressCompleted|json_encode|raw }};
                    const progressAbandoned = {{ progressAbandoned|json_encode|raw }};
                    
                    new Chart(progressCtx, {
                        type: 'line',
                        data: {
                            labels: progressLabels,
                            datasets: [
                                {
                                    label: 'Tâches créées',
                                    data: progressCreated,
                                    borderColor: '#3b82f6',
                                    backgroundColor: '#3b82f620',
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#3b82f6',
                                    pointBorderColor: 'white',
                                    pointRadius: 4,
                                    pointHoverRadius: 6
                                },
                                {
                                    label: 'Tâches terminées',
                                    data: progressCompleted,
                                    borderColor: '#10b981',
                                    backgroundColor: '#10b98120',
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#10b981',
                                    pointBorderColor: 'white',
                                    pointRadius: 4,
                                    pointHoverRadius: 6
                                },
                                {
                                    label: 'Tâches abandonnées',
                                    data: progressAbandoned,
                                    borderColor: '#ef4444',
                                    backgroundColor: '#ef444420',
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#ef4444',
                                    pointBorderColor: 'white',
                                    pointRadius: 4,
                                    pointHoverRadius: 6
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            interaction: {
                                mode: 'index',
                                intersect: false,
                            },
                            plugins: {
                                legend: {
                                    position: 'top',
                                    labels: {
                                        boxWidth: 12,
                                        padding: 15,
                                        usePointStyle: true,
                                        pointStyle: 'circle'
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return context.dataset.label + ': ' + context.raw + ' tâche' + (context.raw > 1 ? 's' : '');
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        stepSize: 1,
                                        precision: 0,
                                        callback: function(value) {
                                            return value + ' tâche' + (value > 1 ? 's' : '');
                                        }
                                    },
                                    grid: {
                                        color: '#e5e7eb',
                                        drawBorder: false
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false
                                    },
                                    ticks: {
                                        maxRotation: 45,
                                        minRotation: 45
                                    }
                                }
                            },
                            elements: {
                                line: {
                                    borderWidth: 2
                                }
                            }
                        }
                    });
                }
            }

            // Weather Modal Function
            function initWeatherModal() {
                const weatherBtn = document.getElementById("weatherBtn");
                const weatherModal = document.getElementById("weatherModal");
                const closeWeatherModal = document.getElementById("closeWeatherModal");
                const weatherResult = document.getElementById("weatherResult");
                
                // Also get the insights modal and its close button to avoid conflicts
                const insightsModal = document.getElementById('insightsModal');
                const blurOverlay = document.getElementById('blur-overlay');

                if (!weatherBtn) return;

                weatherBtn.addEventListener("click", async (e) => {
                    e.preventDefault();
                    
                    // Hide any other open modals/dropdowns
                    if (insightsModal) insightsModal.style.display = 'none';
                    if (blurOverlay) blurOverlay.style.display = 'none';
                    const notifDropdown = document.getElementById('notif-dropdown');
                    if (notifDropdown) notifDropdown.classList.add('hidden');
                    
                    // Show loading state
                    weatherResult.innerHTML = `
                        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem;">
                            <div style="width: 48px; height: 48px; border: 3px solid #f3f4f6; border-top-color: #3b82f6; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 1rem;"></div>
                            <p style="color: var(--gray-600);">Chargement des données météo...</p>
                        </div>
                    `;
                    
                    // Show modal
                    weatherModal.style.display = 'flex';

                    try {
                        let res = await fetch("{{ path('weather_ai') }}");
                        let data = await res.json();

                        weatherResult.innerHTML = `
                            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                <!-- Weather Info Card -->
                                <div style="background: linear-gradient(135deg, #f0f9ff 0%, #e6f2fc 100%); padding: 1.5rem; border-radius: 16px; border-left: 4px solid #3b82f6;">
                                    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                                        <div style="background: #3b82f6; width: 50px; height: 50px; border-radius: 25px; display: flex; align-items: center; justify-content: center;">
                                            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                                                <circle cx="12" cy="12" r="5"/>
                                                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 style="font-size: 1.5rem; font-weight: 700; color: #1e3a8a;">Météo Actuelle</h3>
                                            <p style="color: #3b82f6; font-weight: 500;">${data.weather.description || 'Données météo'}</p>
                                        </div>
                                    </div>
                                    
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                        <div style="background: white; padding: 1rem; border-radius: 12px; text-align: center;">
                                            <div style="font-size: 2rem; font-weight: 800; color: #1e3a8a;">${data.weather.temperature || '--'}°C</div>
                                            <div style="font-size: 0.8rem; color: var(--gray-500);">Température</div>
                                        </div>
                                        <div style="background: white; padding: 1rem; border-radius: 12px; text-align: center;">
                                            <div style="font-size: 1.2rem; font-weight: 600; color: #1e3a8a;">${data.weather.humidity || '--'}%</div>
                                            <div style="font-size: 0.8rem; color: var(--gray-500);">Humidité</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- AI Advice Card -->
                                <div style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); padding: 1.5rem; border-radius: 16px; border-left: 4px solid #8b5cf6;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                                        <div style="background: #8b5cf6; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                                                <path d="M12 2a3 3 0 0 0-3 3c0 1.5 1 4 3 7 2-3 3-5.5 3-7a3 3 0 0 0-3-3z"/>
                                                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
                                                <path d="M2 12h20"/>
                                                <path d="M12 22V12"/>
                                            </svg>
                                        </div>
                                        <h3 style="font-size: 1.2rem; font-weight: 600; color: #4c1d95;">Conseil IA Personnalisé</h3>
                                    </div>
                                    <p style="color: var(--gray-700); line-height: 1.6; font-size: 1rem;">
                                        ${data.ai || 'Aucun conseil disponible pour le moment.'}
                                    </p>
                                </div>

                                <!-- Additional Info -->
                                <div style="display: flex; align-items: center; gap: 0.5rem; padding-top: 1rem; border-top: 1px solid var(--gray-200);">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    <span style="color: var(--gray-500); font-size: 0.8rem;">Mis à jour: ${new Date().toLocaleString('fr-FR')}</span>
                                </div>
                            </div>
                        `;
                    } catch (error) {
                        console.error('Weather error:', error);
                        weatherResult.innerHTML = `
                            <div style="background: #fee2e2; padding: 2rem; border-radius: 12px; text-align: center;">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#b91c1c" stroke-width="2" style="margin: 0 auto 1rem;">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="8" x2="12" y2="12"/>
                                    <circle cx="12" cy="16" r="0.5" fill="#b91c1c" stroke="none"/>
                                </svg>
                                <h3 style="color: #b91c1c; margin-bottom: 0.5rem;">Erreur de chargement</h3>
                                <p style="color: #7f1d1d;">Impossible de récupérer les données météo. Veuillez réessayer.</p>
                                <button onclick="window.location.reload()" style="margin-top: 1rem; padding: 0.5rem 1rem; background: #b91c1c; color: white; border: none; border-radius: 8px; cursor: pointer;">Réessayer</button>
                            </div>
                        `;
                    }
                });

                // Close modal when clicking close button
                if (closeWeatherModal) {
                    closeWeatherModal.addEventListener('click', () => {
                        weatherModal.style.display = 'none';
                    });
                }

                // Close modal when clicking outside
                weatherModal.addEventListener('click', (e) => {
                    if (e.target === weatherModal) {
                        weatherModal.style.display = 'none';
                    }
                });

                // Close modal with Escape key
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape' && weatherModal.style.display === 'flex') {
                        weatherModal.style.display = 'none';
                    }
                });
            }

            // Insights Modal
            const btnInsights = document.getElementById('btnInsights');
            const modal = document.getElementById('insightsModal');
            const closeBtn = document.getElementById('closeInsights');
            const insightsContainer = document.getElementById('insightsContainer');

            // Get stats from Twig
            const total = {{ totalTasks|default(0) }};
            const completed = {{ completedTasks|default(0) }};
            const abandoned = {{ abandonedTasks|default(0) }};
            const inProgress = {{ inProgressTasks|default(0) }};
            const overdue = {{ overdueTasks|default(0) }};
            const high = {{ highPriorityTasks|default(0) }};

            // Compute additional metrics
            const successRate = total > 0 ? Math.round((completed / total) * 100) : 0;
            const productivity = (completed + abandoned + overdue) > 0 
                ? Math.round((completed / (completed + abandoned + overdue)) * 100) 
                : 100;

            if (btnInsights) {
                btnInsights.addEventListener('click', async (e) => {
                    e.preventDefault();
                    
                    // Show loading state
                    insightsContainer.innerHTML = `
                        <div style="display: flex; flex-direction: column; gap: 2rem;">
                            <div style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); padding: 1.5rem; border-radius: 12px; border-left: 4px solid var(--primary);">
                                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                                    <div style="background: var(--primary-light); width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2">
                                            <path d="M21 12v-2a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v2"/>
                                            <path d="M3 12h4l2 3 3-6 2 3 3-3 2 3 2-3"/>
                                            <path d="M3 12v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4"/>
                                        </svg>
                                    </div>
                                    <h3 style="font-size: 1.2rem; font-weight: 600;">Analyse en cours...</h3>
                                </div>
                                <p style="color: var(--gray-700);">
                                    <span style="display: flex; align-items: center; gap: 0.5rem;">
                                        <span style="display: inline-block; width: 16px; height: 16px; border: 2px solid var(--primary-light); border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite;"></span>
                                        Chargement des insights...
                                    </span>
                                </p>
                            </div>
                        </div>
                    `;
                    modal.style.display = 'flex';

                    try {
                        const response = await fetch('{{ path("user_tasks_insights") }}');
                        const data = await response.json();

                        insightsContainer.innerHTML = `
                            <div style="display: flex; flex-direction: column; gap: 2rem;">
                                <!-- Weekly Summary -->
                                <div style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); padding: 1.5rem; border-radius: 12px; border-left: 4px solid var(--primary);">
                                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                                        <div style="background: var(--primary-light); width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2">
                                                <path d="M21 12v-2a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v2"/>
                                                <path d="M3 12h4l2 3 3-6 2 3 3-3 2 3 2-3"/>
                                                <path d="M3 12v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4"/>
                                            </svg>
                                        </div>
                                        <h3 style="font-size: 1.2rem; font-weight: 600;">Résumé de la semaine</h3>
                                    </div>
                                    <p style="color: var(--gray-700);">${data.aiInsights?.weeklyProductivitySummary || 'Aucune donnée disponible pour cette semaine.'}</p>
                                </div>

                                <!-- Personalized Advice -->
                                <div style="background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid var(--gray-200);">
                                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                                        <div style="background: #fef3c7; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                            </svg>
                                        </div>
                                        <h3 style="font-size: 1.2rem; font-weight: 600;">Conseils personnalisés</h3>
                                    </div>
                                    <p style="color: var(--gray-700);">${data.aiInsights?.behavioralAdvice || 'Continuez votre bon travail ! Pas de conseils spécifiques pour le moment.'}</p>
                                </div>

                                <!-- Metrics -->
                                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
                                    <div style="background: var(--gray-50); padding: 1rem; border-radius: 12px; text-align: center;">
                                        <div style="font-size: 0.8rem; color: var(--gray-500); margin-bottom: 0.5rem;">Productivité</div>
                                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);">${productivity}%</div>
                                    </div>
                                    <div style="background: var(--gray-50); padding: 1rem; border-radius: 12px; text-align: center;">
                                        <div style="font-size: 0.8rem; color: var(--gray-500); margin-bottom: 0.5rem;">Complétées</div>
                                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--success);">${completed}</div>
                                    </div>
                                    <div style="background: var(--gray-50); padding: 1rem; border-radius: 12px; text-align: center;">
                                        <div style="font-size: 0.8rem; color: var(--gray-500); margin-bottom: 0.5rem;">Taux réussite</div>
                                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--warning);">${successRate}%</div>
                                    </div>
                                </div>

                                <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem; padding-top: 1rem; border-top: 1px solid var(--gray-200);">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    <span style="color: var(--gray-500); font-size: 0.8rem;">Dernière mise à jour: ${new Date().toLocaleString('fr-FR')}</span>
                                </div>
                            </div>
                        `;
                    } catch (error) {
                        console.error('Insights error:', error);
                        // Fallback
                        insightsContainer.innerHTML = `
                            <div style="display: flex; flex-direction: column; gap: 2rem;">
                                <div style="background: #fff3cd; padding: 1.5rem; border-radius: 12px; border-left: 4px solid #856404;">
                                    <p style="color: #856404;">Impossible de charger les insights personnalisés. Voici vos statistiques :</p>
                                </div>
                                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
                                    <div style="background: var(--gray-50); padding: 1rem; border-radius: 12px; text-align: center;">
                                        <div style="font-size: 0.8rem; color: var(--gray-500);">Productivité</div>
                                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);">${productivity}%</div>
                                    </div>
                                    <div style="background: var(--gray-50); padding: 1rem; border-radius: 12px; text-align: center;">
                                        <div style="font-size: 0.8rem; color: var(--gray-500);">Complétées</div>
                                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--success);">${completed}</div>
                                    </div>
                                    <div style="background: var(--gray-50); padding: 1rem; border-radius: 12px; text-align: center;">
                                        <div style="font-size: 0.8rem; color: var(--gray-500);">Taux réussite</div>
                                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--warning);">${successRate}%</div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                });
            }

            if (closeBtn) {
                closeBtn.addEventListener('click', () => {
                    modal.style.display = 'none';
                });
            }

            if (modal) {
                modal.addEventListener('click', (e) => {
                    if (e.target === modal) {
                        modal.style.display = 'none';
                    }
                });
            }
    </script>
</body>
</html>